---
import Base from "./Base.astro";

interface Props {
  title: string;
  date: string;
  dek?: string;
  description?: string;
}

const { title, date, dek, description } = Astro.props;
---

<Base title={`${title} · Tony Yang`} description={description ?? dek}>
  <!-- Reading progress: a 1px accent bar that grows with scroll. JS
       below sets the --post-progress CSS var; the rule is reduced-motion
       safe by virtue of being a width transition not an animation. -->
  <div class="post-progress" aria-hidden="true"></div>

  <article class="post max-content">
    <header class="post__header">
      <p class="post__date">{date}</p>
      <h1 class="post__title">{title}</h1>
      {dek && <p class="post__dek">{dek}</p>}
    </header>
    <div class="post__body">
      <slot />
    </div>
  </article>
</Base>

<script is:inline>
  // Update the --post-progress CSS var on scroll. Cheap, no observer,
  // single requestAnimationFrame coalesce.
  (function () {
    const bar = document.querySelector(".post-progress");
    const article = document.querySelector(".post");
    if (!bar || !article) return;
    let ticking = false;

    function update() {
      const rect = article.getBoundingClientRect();
      const total = article.scrollHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(window.scrollY - (article.offsetTop - 40), 0), Math.max(total - 80, 1));
      const ratio = total > 80 ? scrolled / (total - 80) : 0;
      bar.style.setProperty("--post-progress", String(Math.min(1, Math.max(0, ratio))));
      ticking = false;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    document.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    document.addEventListener("astro:page-load", () => {
      // Re-attach if the layout was rendered via View Transitions.
      onScroll();
    });
    update();
  })();
</script>

<style>
  /* Reading-progress bar: a 1px accent rule pinned to the top of the
     viewport that grows as the reader makes their way down the post.
     Quietly cinematic. */
  .post-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    pointer-events: none;
    z-index: 50;
  }

  .post-progress::before {
    content: "";
    display: block;
    height: 100%;
    width: calc(100% * var(--post-progress, 0));
    background: var(--color-accent);
    transition: width var(--motion-tap);
    transform-origin: left;
  }

  .post {
    padding-block: 96px;
    max-width: 720px;
  }

  .post__date {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .post__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1.1;
    margin: 0;
    text-wrap: balance;
  }

  .post__dek {
    margin: 16px 0 0;
    font-style: italic;
    font-size: 18px;
    color: var(--color-ink-soft);
    max-width: 50ch;
    text-wrap: pretty;
  }

  .post__body {
    margin-top: 48px;
    font-size: 17px;
    line-height: 1.75;
  }

  /* Lettrine on the first paragraph: an upright EB Garamond cap drops
     ~3 lines into the prose, in accent emerald. The print tradition. */
  .post__body :global(> p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: 3.6em;
    line-height: 0.82;
    padding-top: 0.06em;
    margin: 0 0.1em 0 0;
    color: var(--color-accent);
  }

  /* Small caps on the first line so the opening reads as a frontispiece
     before settling into the lower-case body. */
  .post__body :global(> p:first-of-type::first-line) {
    font-variant: small-caps;
    letter-spacing: 0.04em;
  }

  /* Numbered marginalia on h2: a roman numeral hangs to the left of
     each section break, like a printed essay. */
  .post__body :global(h2) {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 28px;
    margin-top: 56px;
    line-height: 1.15;
    counter-increment: post-h2;
    position: relative;
    padding-left: 56px;
    text-wrap: balance;
  }

  .post__body :global(h2)::before {
    content: counter(post-h2, upper-roman) ".";
    position: absolute;
    left: 0;
    top: 0.1em;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    font-feature-settings: "lnum", "tnum";
  }

  @media (max-width: 720px) {
    .post__body :global(h2) {
      padding-left: 44px;
    }
    .post__body :global(h2)::before {
      font-size: 12px;
    }
  }

  .post__body :global(p) {
    margin-block: 1em;
    text-wrap: pretty;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .post__body :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: rgba(74, 81, 89, 0.4);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color var(--motion-warm), text-decoration-color var(--motion-warm);
  }

  .post__body :global(a:hover),
  .post__body :global(a:focus-visible) {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .post__body :global(blockquote) {
    margin: 28px 0;
    padding: 4px 0 4px 24px;
    border-left: 2px solid var(--color-accent);
    color: var(--color-ink-soft);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .post__body :global(pre) {
    background: var(--color-paper-shade);
    border: 1px solid var(--color-hairline);
    padding: 16px;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
  }

  .post__body :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
  }

  /* Inline code in running prose gets a quiet paper-shade tint so it
     reads as type rather than UI chrome. */
  .post__body :global(p code),
  .post__body :global(li code) {
    background: var(--color-paper-shade);
    border: 1px solid var(--color-hairline);
    padding: 0 5px;
    border-radius: 3px;
    font-size: 0.92em;
  }

  /* Reset the h2 counter at the article boundary so it starts at I */
  .post__body {
    counter-reset: post-h2;
  }
</style>
