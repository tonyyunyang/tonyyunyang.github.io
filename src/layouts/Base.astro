---
import "~/styles/globals.css";
import { ClientRouter } from "astro:transitions";
import CommandPalette from "~/components/CommandPalette.astro";
import BibtexModal from "~/components/BibtexModal.astro";
import SketchbookButton from "~/components/SketchbookButton.astro";
import RunningHead from "~/components/RunningHead.astro";

interface RunningHeadSection {
  id: string;
  num: string;
  title: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideSketchbook?: boolean;
  hideRunningHead?: boolean;
  runningHeadSections?: RunningHeadSection[];
  runningHeadName?: string;
  runningHeadNum?: string;
}

const {
  title = "Tony Yang",
  description = "Independent AI researcher in Amsterdam. I work on the hard, useful parts of AI, mostly LLM efficiency and low-data problems.",
  ogImage = "/og-default.png",
  hideSketchbook = false,
  hideRunningHead = false,
  runningHeadSections = [],
  runningHeadName,
  runningHeadNum,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Tony Yang" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" type="application/rss+xml" title="Tony Yang · Writing" href="/rss.xml" />

    <ClientRouter />
  </head>
  <body>
    <a class="sr-only focus:not-sr-only" href="#main">Skip to content</a>
    {!hideRunningHead && (
      <RunningHead
        sections={runningHeadSections}
        pageName={runningHeadName}
        pageNum={runningHeadNum}
      />
    )}
    <main id="main">
      <slot />
    </main>
    <CommandPalette />
    <BibtexModal />
    {!hideSketchbook && <SketchbookButton />}

    <div aria-hidden="true" class="visit-tracker">
      <script
        is:inline
        type="text/javascript"
        id="clustrmaps"
        src="//clustrmaps.com/map_v2.js?d=iKkpkHnNrRabuXubBkrbYyRqd19Zjt1GhUxkeyjBjPA&cl=ffffff&w=a"
      ></script>
    </div>

    <style>
      .visit-tracker {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
        pointer-events: none;
      }
    </style>
  </body>
</html>
