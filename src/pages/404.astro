---
import Base from "~/layouts/Base.astro";
import { getCollection } from "astro:content";

const recent = (await getCollection("posts", (p) => !p.data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
---

<Base
  title="Lost · Tony Yang"
  description="This page wandered off."
  runningHeadName="Lost"
  runningHeadNum="404"
>
  <section class="lost">
    <p class="lost__corner">
      <span class="lost__corner-mark" aria-hidden="true">§</span>
      No. 404 · Lost in the Studio
    </p>

    <div class="lost__plate">
      <!-- A small printed vignette: a single bird in flight under a
           moon and a few stars, drifting away from a distant gable
           silhouette. Carries the Hero's window-onto-more vocabulary
           into a page that would otherwise be plain text. -->
      <svg
        class="lost__sketch"
        viewBox="0 0 360 220"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <defs>
          <radialGradient id="lostMoonHalo" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.85" />
            <stop offset="0.55" stop-color="#FAF1D8" stop-opacity="0.35" />
            <stop offset="1" stop-color="#FAF1D8" stop-opacity="0" />
          </radialGradient>
        </defs>

        <!-- moon -->
        <circle cx="280" cy="56" r="36" fill="url(#lostMoonHalo)" stroke="none" />
        <circle cx="280" cy="56" r="14" fill="#FAF1D8" stroke-width="1.2" />
        <path d="M280 42 A 14 14 0 0 1 294 56 A 14 14 0 0 1 280 70 A 12 12 0 0 0 280 42 Z" fill="currentColor" opacity="0.18" stroke="none" />

        <!-- stars -->
        <circle cx="60" cy="28" r="0.9" fill="currentColor" stroke="none" />
        <circle cx="100" cy="44" r="1.1" fill="currentColor" stroke="none" />
        <circle cx="140" cy="22" r="0.7" fill="currentColor" stroke="none" />
        <circle cx="186" cy="62" r="1" fill="currentColor" stroke="none" />
        <circle cx="222" cy="32" r="0.8" fill="currentColor" stroke="none" />
        <path d="M148 48 L148 44 M148 48 L148 52 M148 48 L144 48 M148 48 L152 48" stroke-width="0.5" opacity="0.7" />

        <!-- distant gables (something to fly away from) -->
        <path
          d="M28 168 L40 168 L40 156 L52 156 L52 148 L62 148 L62 156 L74 156 L74 168 L86 168 L86 152 L94 146 L102 142 L110 146 L118 152 L118 168 L128 168 L128 156 L136 156 L136 162 L146 162 L146 156 L156 156 L156 168 L168 168"
          stroke-width="1.2"
          fill="#EDE6D5"
          opacity="0.75"
        />

        <!-- bird in flight, mid-flap, drifting toward the right edge -->
        <g class="lost__bird">
          <path d="M196 100 Q204 88 214 100 Q224 88 232 100" stroke-width="1.2" />
          <path d="M236 108 Q243 100 250 108" stroke-width="0.9" opacity="0.7" />
          <path d="M256 116 Q260 112 264 116" stroke-width="0.7" opacity="0.55" />
        </g>

        <!-- ink trail behind the bird (where it came from) -->
        <path d="M40 124 Q60 130 88 124 Q116 118 144 124 Q172 130 196 124" stroke-width="0.5" stroke-dasharray="2 5" opacity="0.55" />
        <circle cx="40" cy="124" r="1.4" fill="currentColor" stroke="none" opacity="0.75" />

        <!-- horizon rule -->
        <path d="M0 168 H360" stroke-width="1" opacity="0.85" />

        <!-- caption -->
        <text x="180" y="200" text-anchor="middle" font-family="EB Garamond, serif" font-style="italic" font-size="13" fill="currentColor" stroke="none" opacity="0.7">nothing here</text>
      </svg>
    </div>

    <h1 class="lost__title">The page wandered off.</h1>
    <p class="lost__copy">
      Try the <a class="link-ink" href="/">home page</a>, open the <a class="link-ink" href="/world/">studio</a>, or browse the <a class="link-ink" href="/writing/">writing</a>.
    </p>

    {recent.length > 0 && (
      <aside class="lost__recent">
        <p class="lost__recent-label">Or you might be looking for</p>
        <ul class="lost__recent-list">
          {recent.map((p) => (
            <li>
              <a href={`/writing/${p.slug}/`}>
                <span class="lost__recent-date">{p.data.date}</span>
                <span class="lost__recent-title">{p.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <p class="lost__plate-mark">PLATE 404 · MISSING</p>
  </section>
</Base>

<style>
  .lost {
    position: relative;
    max-width: var(--content-max);
    margin: 96px auto;
    padding: 24px;
    text-align: center;
  }

  .lost__corner {
    margin: 0 0 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .lost__corner-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-accent);
    margin-right: 6px;
    vertical-align: -1px;
  }

  .lost__plate {
    margin: 0 auto 32px;
    width: min(100%, 360px);
    color: var(--color-ink);
  }

  .lost__sketch {
    display: block;
    width: 100%;
    height: auto;
  }

  /* The bird drifts gently toward the right edge, animation honors the
     reduced-motion preference via the global block in globals.css. */
  .lost__bird {
    transform-origin: center;
    transform-box: fill-box;
    animation: lostBirdDrift 6s ease-in-out infinite;
  }

  @keyframes lostBirdDrift {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(6px, -3px); }
  }

  .lost__title {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(36px, 6vw, 56px);
    color: var(--color-ink);
    text-wrap: balance;
  }

  .lost__copy {
    margin: 0 auto 56px;
    max-width: 48ch;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--color-ink-soft);
  }

  .lost__recent {
    margin: 0 auto;
    max-width: 520px;
    padding: 28px 32px 30px;
    background: var(--color-paper-shade);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    text-align: left;
    position: relative;
  }

  /* Hand-drawn corner brackets so the recent-list reads as a specimen
     card pinned to the page, not a generic info box. */
  .lost__recent::before,
  .lost__recent::after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    border: 1.4px solid var(--color-ink);
    pointer-events: none;
  }

  .lost__recent::before {
    top: 8px;
    left: 8px;
    border-right: 0;
    border-bottom: 0;
  }

  .lost__recent::after {
    bottom: 8px;
    right: 8px;
    border-left: 0;
    border-top: 0;
  }

  .lost__recent-label {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    text-align: center;
  }

  .lost__recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lost__recent-list a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: baseline;
    color: var(--color-ink);
    text-decoration: none;
    padding: 6px 4px;
    border-radius: 3px;
    transition: background var(--motion-tap), color var(--motion-tap);
  }

  .lost__recent-list a:hover {
    background: var(--color-paper);
    color: var(--color-accent);
  }

  .lost__recent-date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .lost__recent-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    line-height: 1.3;
  }

  .lost__plate-mark {
    margin: 56px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    opacity: 0.75;
  }

  @media (max-width: 720px) {
    .lost {
      margin: 56px auto;
    }
    .lost__plate {
      width: min(100%, 280px);
    }
    .lost__recent {
      padding: 22px 22px 24px;
    }
    .lost__recent-list a {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lost__bird {
      animation: none;
    }
  }
</style>
