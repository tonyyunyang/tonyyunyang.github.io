---
import Base from "~/layouts/Base.astro";

const tokens = [
  { name: "paper",       value: "#F5EFE2", role: "primary background" },
  { name: "paper-shade", value: "#EDE6D5", role: "card + plate fill" },
  { name: "ink",         value: "#0F1417", role: "primary text" },
  { name: "ink-soft",    value: "#4A5159", role: "secondary text + meta" },
  { name: "accent",      value: "#0E5347", role: "links + highlights" },
  { name: "hairline",    value: "#D9D2C2", role: "borders + dividers" },
  { name: "featured",    value: "#FAF1D8", role: "featured tints" },
];

const faces = [
  { face: "EB Garamond",      role: "display", weights: "400 + 500, italic + upright", source: "Google Fonts (free)" },
  { face: "Inter",            role: "body sans", weights: "400 / 500 / 600 + 400 italic", source: "Google Fonts (free)" },
  { face: "JetBrains Mono",   role: "captions, codes, dates", weights: "400 / 500", source: "JetBrains (free)" },
  { face: "LXGW WenKai",      role: "Chinese display", weights: "500", source: "霞鹜文楷, OFL (free)" },
];

const tools = [
  { tool: "Astro 5",        url: "https://astro.build",     note: "static site framework, MDX content collections" },
  { tool: "Tailwind v4",    url: "https://tailwindcss.com", note: "design tokens via @theme block" },
  { tool: "Pagefind",       url: "https://pagefind.app",    note: "client-side fuzzy search powering ⌘K" },
  { tool: "Playwright",     url: "https://playwright.dev",  note: "visual checkpoints + the OG render helper" },
  { tool: "GitHub Pages",   url: "https://pages.github.com",note: "deploy via Actions on every push to main" },
];
---

<Base
  title="Colophon · Tony Yang"
  description="The typography, palette, and tools behind this site."
  runningHeadName="Colophon"
  runningHeadNum="C"
>
  <article class="colophon max-content">
    <header class="colophon__header">
      <p class="colophon__eyebrow">
        <span class="colophon__eyebrow-mark" aria-hidden="true">§</span>
        Colophon
      </p>
      <h1 class="colophon__title">A note on the typography, the palette, and the tools.</h1>
      <p class="colophon__dek">
        This page is here because every printed plate names its inks. The same
        spirit applies on the web.
      </p>
      <span class="colophon__rule" aria-hidden="true"></span>
    </header>

    <section class="colophon__section">
      <h2 class="colophon__section-title">
        <span class="colophon__section-num">I.</span>
        <span class="colophon__section-label">Type</span>
      </h2>
      <p class="colophon__lede">
        Three faces, plus a calligraphic Chinese companion. The display
        carries the prose, the sans carries the deks, and the mono carries
        the marginalia (numbers, captions, dates, codes).
      </p>
      <ul class="colophon__faces">
        {faces.map((f) => (
          <li class="colophon__face">
            <p class="colophon__face-name" style={f.face === "LXGW WenKai" ? "font-family: var(--font-display-zh)" : f.face === "Inter" ? "font-family: var(--font-sans)" : f.face === "JetBrains Mono" ? "font-family: var(--font-mono)" : "font-family: var(--font-display); font-style: italic;"}>
              {f.face}
            </p>
            <p class="colophon__face-meta">
              <span class="colophon__face-role">{f.role}</span>
              <span class="colophon__face-sep" aria-hidden="true">·</span>
              <span class="colophon__face-weights">{f.weights}</span>
            </p>
            <p class="colophon__face-source">{f.source}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="colophon__section">
      <h2 class="colophon__section-title">
        <span class="colophon__section-num">II.</span>
        <span class="colophon__section-label">Palette</span>
      </h2>
      <p class="colophon__lede">
        Seven tokens, no eighth. Paper and ink make the page. Emerald
        carries every link. Featured cream sits behind the things you
        most want a visitor to see.
      </p>
      <ul class="colophon__palette">
        {tokens.map((t) => (
          <li class="colophon__swatch">
            <span class="colophon__swatch-chip" style={`background: ${t.value};`} aria-hidden="true"></span>
            <span class="colophon__swatch-name">{t.name}</span>
            <span class="colophon__swatch-value">{t.value}</span>
            <span class="colophon__swatch-role">{t.role}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="colophon__section">
      <h2 class="colophon__section-title">
        <span class="colophon__section-num">III.</span>
        <span class="colophon__section-label">Tools</span>
      </h2>
      <p class="colophon__lede">
        Fewer than you'd expect. No React, no SSR, no design framework,
        no template ancestry. The site is hand-set in Astro and ships
        through GitHub Actions.
      </p>
      <ul class="colophon__tools">
        {tools.map((t) => (
          <li class="colophon__tool">
            <a class="link-ink" href={t.url} target="_blank" rel="noopener noreferrer">{t.tool}</a>
            <span class="colophon__tool-note">{t.note}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="colophon__section">
      <h2 class="colophon__section-title">
        <span class="colophon__section-num">IV.</span>
        <span class="colophon__section-label">Motion</span>
      </h2>
      <p class="colophon__lede">
        Three durations, three shapes. <em>Tap</em> is for direct feedback
        (160 ms, ease‑in‑out). <em>Warm</em> is for state shifts (280 ms,
        cubic ease). <em>Reveal</em> is for entries (600 ms, cinematic).
        All of it honors <code>prefers-reduced-motion</code>.
      </p>
    </section>

    <section class="colophon__section">
      <h2 class="colophon__section-title">
        <span class="colophon__section-num">V.</span>
        <span class="colophon__section-label">Author</span>
      </h2>
      <p class="colophon__lede">
        Designed and built by <a class="link-ink" href="/">Tony Yang</a> in
        Amsterdam, between papers. Source is on
        <a class="link-ink" href="https://github.com/tonyyunyang/tonyyunyang.github.io" target="_blank" rel="noopener noreferrer">GitHub</a>.
        The studio is <a class="link-ink" href="/world/">here</a>.
      </p>
    </section>

    <p class="colophon__plate-mark">PLATE C · COLOPHON</p>
  </article>
</Base>

<style>
  .colophon {
    padding-block: 96px 120px;
  }

  .colophon__header {
    margin-bottom: 48px;
  }

  .colophon__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .colophon__eyebrow-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-accent);
    margin-right: 6px;
    vertical-align: -1px;
  }

  .colophon__title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(32px, 4.4vw, 52px);
    line-height: 1.1;
    color: var(--color-ink);
    text-wrap: balance;
    max-width: 26ch;
  }

  .colophon__dek {
    margin: 18px 0 0;
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.6;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }

  .colophon__rule {
    display: block;
    margin-top: 24px;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .colophon__section {
    margin-top: 72px;
  }

  .colophon__section-title {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin: 0 0 20px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.05;
    color: var(--color-ink);
  }

  .colophon__section-num {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    transform: translateY(-2px);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .colophon__lede {
    margin: 0 0 24px;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 60ch;
    text-wrap: pretty;
  }

  .colophon__lede em {
    font-family: var(--font-display);
    font-size: 1.05em;
    color: var(--color-accent);
  }

  .colophon__lede code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-ink-soft);
    background: var(--color-paper-shade);
    padding: 1px 6px;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
  }

  /* ============ Faces ============ */

  .colophon__faces {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 720px) {
    .colophon__faces {
      grid-template-columns: 1fr;
    }
  }

  .colophon__face {
    padding: 20px 22px 22px;
    background: var(--color-paper-shade);
    border-radius: 6px;
    border: 1px solid var(--color-hairline);
  }

  .colophon__face-name {
    margin: 0 0 10px;
    font-size: 32px;
    line-height: 1;
    color: var(--color-ink);
    font-feature-settings: "kern", "liga", "calt", "dlig";
  }

  .colophon__face-meta {
    margin: 0 0 4px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .colophon__face-sep {
    opacity: 0.55;
  }

  .colophon__face-source {
    margin: 6px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-ink-soft);
  }

  /* ============ Palette ============ */

  .colophon__palette {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .colophon__swatch {
    display: grid;
    grid-template-columns: 28px auto auto 1fr;
    align-items: center;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-hairline);
  }

  .colophon__swatch:last-child {
    border-bottom: 0;
  }

  .colophon__swatch-chip {
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
  }

  .colophon__swatch-name {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--color-ink);
  }

  .colophon__swatch-value {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
  }

  .colophon__swatch-role {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-ink-soft);
    text-align: right;
  }

  @media (max-width: 720px) {
    .colophon__swatch {
      grid-template-columns: 28px auto 1fr;
      grid-template-rows: auto auto;
      gap: 4px 14px;
    }
    .colophon__swatch-name {
      grid-column: 2 / 3;
      grid-row: 1 / 2;
    }
    .colophon__swatch-value {
      grid-column: 3 / 4;
      grid-row: 1 / 2;
      text-align: right;
    }
    .colophon__swatch-role {
      grid-column: 2 / 4;
      grid-row: 2 / 3;
      text-align: left;
    }
  }

  /* ============ Tools ============ */

  .colophon__tools {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .colophon__tool {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-hairline);
  }

  .colophon__tool:last-child {
    border-bottom: 0;
  }

  .colophon__tool-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-ink-soft);
  }

  @media (max-width: 720px) {
    .colophon__tool {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }

  /* ============ Plate mark ============ */

  .colophon__plate-mark {
    margin: 96px 0 0;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    opacity: 0.75;
  }
</style>
