---
import "~/styles/globals.css";
import siteConfig from "~/content/site.json";

const card = siteConfig.businessCard;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>OG · default</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="og">
    <div class="og__plate">
      <!-- top corners -->
      <p class="og__corner og__corner--left">
        <span class="og__corner-mark">§</span>
        No. 01 · Personal
      </p>
      <p class="og__corner og__corner--right">AMSTERDAM · 2026</p>

      <div class="og__layout">
        <div class="og__id">
          <h1 class="og__name">
            <span class="og__name-en">{card.name}</span>
            <span class="og__name-zh">{card.nameZh}</span>
          </h1>
          <p class="og__role">{card.role}</p>
          <p class="og__tagline">{card.tagline}</p>
        </div>

        <!-- twilight window vignette: a tighter spin on Plate I -->
        <svg
          class="og__sketch"
          viewBox="0 0 360 480"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <defs>
            <pattern id="ogHatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(35)">
              <line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="0.4" opacity="0.42" />
            </pattern>
            <radialGradient id="ogMoonHalo" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.85" />
              <stop offset="0.55" stop-color="#FAF1D8" stop-opacity="0.35" />
              <stop offset="1" stop-color="#FAF1D8" stop-opacity="0" />
            </radialGradient>
          </defs>

          <!-- arched window frame, hatched corners, keystone -->
          <path d="M48 70 Q48 44 88 44 H272 Q312 44 312 70 V296 H48 Z" stroke-width="2" fill="#FAF1D8" />
          <path d="M56 78 Q56 52 90 52 H270 Q304 52 304 78 V288 H56 Z" stroke-width="0.6" opacity="0.55" fill="none" />
          <path d="M174 44 L174 60 L186 60 L186 44 Z" stroke-width="0.9" fill="#EDE6D5" />
          <rect x="48" y="70" width="24" height="6" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="48" y="70" width="6" height="24" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="288" y="70" width="24" height="6" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="306" y="70" width="6" height="24" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="48" y="290" width="24" height="6" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="48" y="272" width="6" height="24" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="288" y="290" width="24" height="6" fill="url(#ogHatch)" opacity="0.7" />
          <rect x="306" y="272" width="6" height="24" fill="url(#ogHatch)" opacity="0.7" />

          <!-- sky pane -->
          <rect x="56" y="78" width="248" height="100" fill="#FAF1D8" />

          <!-- moon halo + crescent -->
          <circle cx="252" cy="106" r="42" fill="url(#ogMoonHalo)" stroke="none" />
          <circle cx="252" cy="106" r="16" fill="#FAF1D8" stroke-width="1.4" />
          <circle cx="246" cy="102" r="13" fill="#FAF1D8" stroke="none" />
          <path d="M252 90 A 16 16 0 0 1 268 106 A 16 16 0 0 1 252 122 A 14 14 0 0 0 252 90 Z" fill="currentColor" opacity="0.18" stroke="none" />

          <!-- stars -->
          <circle cx="78" cy="92" r="1.1" fill="currentColor" stroke="none" />
          <circle cx="106" cy="86" r="0.9" fill="currentColor" stroke="none" />
          <circle cx="124" cy="116" r="1.2" fill="currentColor" stroke="none" />
          <circle cx="170" cy="92" r="0.7" fill="currentColor" stroke="none" />
          <circle cx="206" cy="98" r="0.9" fill="currentColor" stroke="none" />

          <!-- gabled silhouette + church spire -->
          <path
            d="M56 178 L70 178 L70 162 L80 162 L80 152 L92 152 L92 162 L106 162 L106 178 L120 178 L120 156 L130 150 L140 142 L150 150 L160 156 L160 178 L172 178 L172 158 L184 158 L184 168 L196 168 L196 158 L208 158 L208 178 L222 178 L218 168 L226 158 L228 154 L228 130 L226 124 L232 124 L232 102 L236 100 L240 102 L240 124 L246 124 L244 130 L244 154 L246 158 L254 168 L250 178 L268 178 L268 152 L280 152 L280 144 L294 144 L294 156 L304 156 L304 178"
            stroke-width="1.4"
            fill="#EDE6D5"
          />

          <!-- lit windows -->
          <rect x="76" y="168" width="3" height="5" fill="#0E5347" stroke="none" />
          <rect x="98" y="168" width="3" height="5" fill="#0E5347" stroke="none" />
          <rect x="128" y="160" width="3" height="5" fill="#0E5347" stroke="none" />
          <rect x="200" y="166" width="3" height="5" fill="#0E5347" stroke="none" />
          <rect x="284" y="156" width="3" height="5" fill="#0E5347" stroke="none" />

          <!-- canal water -->
          <rect x="56" y="180" width="248" height="62" fill="#EDE6D5" />
          <path d="M56 180 H304" stroke-width="0.7" />
          <path d="M244 192 H262 M242 200 H264 M246 208 H260" stroke-width="1" opacity="0.55" stroke="#FAF1D8" />
          <path d="M62 198 Q78 195 94 198 Q110 201 126 198 Q142 195 158 198 Q174 201 190 198 Q206 195 222 198 Q238 201 254 198 Q270 195 286 198 Q298 200 302 198" stroke-width="0.5" opacity="0.65" />
          <path d="M62 222 Q78 219 94 222 Q110 225 126 222 Q142 219 158 222 Q174 225 190 222 Q206 219 222 222 Q238 225 254 222 Q270 219 286 222 Q298 224 302 222" stroke-width="0.5" opacity="0.4" />

          <!-- sill -->
          <path d="M40 242 H320 V258 H40 Z" fill="#EDE6D5" stroke-width="1.4" />
          <path d="M40 258 H320" stroke-width="0.5" opacity="0.55" />

          <!-- mullion + transom -->
          <path d="M180 78 V242" stroke-width="1.4" />
          <path d="M56 178 H304" stroke-width="1" opacity="0.85" />

          <!-- plate label -->
          <path d="M40 364 H320" stroke-width="0.4" opacity="0.4" />
          <text x="40" y="380" font-family="JetBrains Mono, monospace" font-size="11" fill="currentColor" stroke="none" letter-spacing="0.18em" opacity="0.75">PLATE I · TWILIGHT</text>
          <text x="320" y="380" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="11" fill="currentColor" stroke="none" letter-spacing="0.18em" opacity="0.75">2026</text>
        </svg>
      </div>

      <p class="og__url">tonyyunyang.github.io</p>
    </div>
  </body>
</html>

<style>
  /* The OG card is exported via a Playwright helper at 1200x630.
     It's a one-page layout that mirrors the hero's visual language
     so social embeds (Slack, X, Discord, LinkedIn) carry the same
     printed-plate feel as the site itself. */
  .og {
    margin: 0;
    width: 1200px;
    height: 630px;
    background: var(--color-paper);
    color: var(--color-ink);
    font-feature-settings: "kern", "liga", "calt";
    overflow: hidden;
  }

  .og__plate {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 56px 72px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .og__corner {
    position: absolute;
    top: 40px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    line-height: 1.2;
  }

  .og__corner--left {
    left: 72px;
  }

  .og__corner--right {
    right: 72px;
  }

  .og__corner-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--color-accent);
    margin-right: 6px;
  }

  .og__layout {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: center;
  }

  .og__id {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .og__name {
    margin: 0;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: 96px;
    line-height: 1;
    letter-spacing: -0.012em;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 22px;
    flex-wrap: wrap;
  }

  .og__name-zh {
    font-family: var(--font-display-zh);
    font-weight: 500;
    font-size: 0.42em;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
  }

  .og__role {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 16px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .og__tagline {
    margin: 4px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    line-height: 1.3;
    color: var(--color-ink-soft);
    max-width: 22ch;
  }

  .og__sketch {
    width: 360px;
    height: 480px;
    color: var(--color-ink);
  }

  .og__url {
    position: absolute;
    bottom: 40px;
    left: 72px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
</style>
