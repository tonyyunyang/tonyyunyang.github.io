---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data, slug } = project;

const statusLabel =
  data.status === "shipped"
    ? "SHIPPED"
    : `IN PROGRESS${data.statusDetail ? ` · ${data.statusDetail.toUpperCase()}` : ""}`;

const primaryLink =
  data.links?.site ??
  data.links?.store ??
  data.links?.github ??
  data.links?.paper;
---

<article id={`project-${slug}`} class={`project${primaryLink ? "" : " project--static"}`}>
  {data.thumbnail && (
    primaryLink ? (
      <a
        class="project__thumb"
        href={primaryLink}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${data.title} in a new tab`}
      >
        <img src={data.thumbnail} alt="" loading="lazy" />
        <span class="project__thumb-mark" aria-hidden="true">↗</span>
      </a>
    ) : (
      <div class="project__thumb project__thumb--static" aria-hidden="true">
        <img src={data.thumbnail} alt="" loading="lazy" />
      </div>
    )
  )}
  <div class="project__body">
    <p class="project__meta">
      {data.collaborator ? `${data.collaborator.toUpperCase()} · ` : ""}
      <span>{data.period.toUpperCase()}</span>
      <span> · </span>
      <span class="project__status">{statusLabel}</span>
    </p>
    <h3 class="project__title">
      {primaryLink ? (
        <a href={primaryLink} target="_blank" rel="noopener noreferrer">{data.title}</a>
      ) : data.title}
    </h3>
    <p class="project__summary">{data.summary}</p>
    {data.links && (data.links.github || data.links.store || data.links.site || data.links.paper) && (
      <p class="project__links">
        {data.links.github && <a href={data.links.github} target="_blank" rel="noopener noreferrer">github</a>}
        {data.links.github && data.links.store && <span> · </span>}
        {data.links.store && <a href={data.links.store} target="_blank" rel="noopener noreferrer">chrome web store</a>}
        {data.links.site && <span> · <a href={data.links.site} target="_blank" rel="noopener noreferrer">site</a></span>}
        {data.links.paper && <span> · <a href={data.links.paper} target="_blank" rel="noopener noreferrer">paper</a></span>}
      </p>
    )}
  </div>
</article>

<style>
  .project {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 24px;
    padding: 20px 24px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-card);
    background: var(--color-paper-shade);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.02),
      0 2px 4px -2px rgba(15, 20, 23, 0.04);
    transition:
      border-color var(--motion-warm),
      box-shadow var(--motion-warm);
  }

  @media (max-width: 720px) {
    .project {
      grid-template-columns: 1fr;
    }
  }

  /* ProjectCard hover language is interior, not a whole-card lift —
     PaperCard already owns the lift. The thumb subtly zooms, the
     external-link chevron warms to accent + nudges, and the card's
     border softens to accent. No translateY so the row doesn't dance. */
  .project:not(.project--static):hover {
    border-color: var(--color-accent);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 6px 14px -10px rgba(15, 20, 23, 0.15);
  }

  .project__thumb {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-thumb);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-paper);
    transition: border-color var(--motion-warm);
  }

  .project__thumb--static {
    cursor: default;
  }

  .project__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--motion-warm);
  }

  .project:not(.project--static):hover .project__thumb {
    border-color: var(--color-accent);
  }

  .project:not(.project--static):hover .project__thumb img {
    transform: scale(1.02);
  }

  /* "↗" external-link mark, persistent in the corner of every linked
     thumb so the affordance is visible even at rest. Warms to accent
     and slides on hover, signaling the click goes off-site. */
  .project__thumb-mark {
    position: absolute;
    top: 8px;
    right: 9px;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper);
    border: 1px solid var(--color-hairline);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-soft);
    pointer-events: none;
    transition:
      color var(--motion-warm),
      border-color var(--motion-warm),
      transform var(--motion-warm);
  }

  .project:not(.project--static):hover .project__thumb-mark {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .project__thumb img,
    .project__thumb-mark {
      transition: none;
      transform: none;
    }
  }

  .project__meta {
    margin: 0 0 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .project__status {
    color: var(--color-accent);
  }

  .project__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.25;
    font-style: italic;
    font-weight: 500;
  }

  .project__title a {
    color: inherit;
  }

  .project__title a:hover {
    color: var(--color-accent);
  }

  .project__summary {
    margin: 6px 0 0;
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  .project__links {
    margin: 8px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
</style>
