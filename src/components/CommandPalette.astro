---
import siteConfig from "~/content/site.json";

const exposed = {
  contact: siteConfig.contact,
  currently: siteConfig.currently,
};

// One source of truth for the palette items: label, description,
// and command id. Adding a new row only needs an extra entry here +
// a case in src/scripts/command-palette.ts.
const commands = [
  { cmd: "papers",   label: "papers",   desc: "jump to research" },
  { cmd: "projects", label: "projects", desc: "jump to projects" },
  { cmd: "writing",  label: "writing",  desc: "open the blog" },
  { cmd: "latest",   label: "latest",   desc: "most recent paper" },
  { cmd: "cv-en",    label: "cv",       desc: "english pdf" },
  { cmd: "cv-zh",    label: "cv",       desc: "中文 pdf" },
  { cmd: "email",    label: "email",    desc: "compose" },
  { cmd: "world",    label: "world",    desc: "open the studio" },
  { cmd: "colophon", label: "colophon", desc: "type, palette, tools" },
  { cmd: "pace",     label: "pace",     desc: "half-marathon pb" },
  { cmd: "now",      label: "now",      desc: "what I'm working on" },
  { cmd: "theme",    label: "theme",    desc: "toggle (coming soon)", disabled: true },
  { cmd: "help",     label: "?",        desc: "help" },
];
---

<div class="cmdk" data-cmdk hidden>
  <button class="cmdk__veil" type="button" aria-label="Close command palette" data-cmdk-close></button>
  <div class="cmdk__panel" role="dialog" aria-modal="true" aria-label="Command palette">
    <!-- Printer's-plate frame: a dashed outer ring + a solid inner
         frame + corner hatches, identical vocabulary to BusinessCard.
         Sits behind the content, doesn't intercept clicks. -->
    <svg class="cmdk__plate" viewBox="0 0 800 460" aria-hidden="true" preserveAspectRatio="none">
      <defs>
        <pattern id="cmdkHatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(35)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="#0F1417" stroke-width="0.4" opacity="0.5" />
        </pattern>
      </defs>
      <rect x="6" y="6" width="788" height="448" fill="none" stroke="#0F1417" stroke-width="0.6" stroke-dasharray="3 4" opacity="0.45" />
      <rect x="14" y="14" width="772" height="432" fill="none" stroke="#0F1417" stroke-width="1" opacity="0.85" />
      <rect x="14" y="14" width="56" height="12" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="14" y="14" width="12" height="56" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="730" y="14" width="56" height="12" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="774" y="14" width="12" height="56" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="14" y="434" width="56" height="12" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="14" y="378" width="12" height="56" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="730" y="434" width="56" height="12" fill="url(#cmdkHatch)" opacity="0.5" />
      <rect x="774" y="378" width="12" height="56" fill="url(#cmdkHatch)" opacity="0.5" />
    </svg>

    <div class="cmdk__inner">
      <p class="cmdk__title" aria-hidden="true">
        <span class="cmdk__title-mark">§</span>
        Quick navigation
      </p>
      <input
        class="cmdk__input"
        type="text"
        placeholder="search the studio…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        data-cmdk-input
      />
      <ul class="cmdk__results" role="listbox" data-cmdk-results>
        {commands.map((c) => (
          <li
            role="option"
            data-cmd={c.cmd}
            data-cmd-disabled={c.disabled ? "" : undefined}
          >
            <span class="cmdk__cmd-label">{c.label}</span>
            <span class="cmdk__cmd-sep" aria-hidden="true">·</span>
            <span class="cmdk__cmd-desc">{c.desc}</span>
          </li>
        ))}
      </ul>
      <p class="cmdk__hint" data-cmdk-hint></p>
      <p class="cmdk__keys" aria-hidden="true">
        <kbd>↑</kbd><kbd>↓</kbd> to move · <kbd>↵</kbd> to pick · <kbd>esc</kbd> to close
      </p>
    </div>
  </div>
</div>

<script is:inline define:vars={{ exposed }}>
  window.__siteConfig = exposed;
</script>
<script>
  import "~/scripts/command-palette";
</script>

<style>
  .cmdk {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: start center;
    padding-top: 18vh;
  }

  .cmdk[hidden] {
    display: none;
  }

  /* Vignetted veil: a radial darken instead of a flat overlay so the
     palette feels lit from within rather than dropped on top. */
  .cmdk__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center,
        rgba(15, 20, 23, 0.18),
        rgba(15, 20, 23, 0.5));
    backdrop-filter: blur(3px);
    border: 0;
    cursor: default;
    animation: cmdkVeilIn var(--motion-warm) both;
  }

  @keyframes cmdkVeilIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .cmdk__panel {
    position: relative;
    width: min(560px, calc(100% - 48px));
    background: var(--color-paper);
    border-radius: 6px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 24px 60px rgba(15, 20, 23, 0.22);
    animation: cmdkPanelIn var(--motion-reveal) both;
  }

  @keyframes cmdkPanelIn {
    from { opacity: 0; transform: translateY(-8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .cmdk__plate {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-ink);
    pointer-events: none;
  }

  .cmdk__inner {
    position: relative;
    z-index: 1;
    padding: 18px 20px 14px;
  }

  .cmdk__title {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .cmdk__title-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-accent);
    line-height: 1;
  }

  .cmdk__input {
    display: block;
    width: 100%;
    padding: 12px 4px 14px;
    border: 0;
    background: transparent;
    border-bottom: 1px solid var(--color-hairline);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .cmdk__input::placeholder {
    color: var(--color-ink-soft);
    opacity: 0.7;
    font-style: italic;
  }

  .cmdk__input:focus {
    outline: 0;
    border-bottom-color: var(--color-accent);
  }

  .cmdk__results {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    max-height: 320px;
    overflow-y: auto;
  }

  .cmdk__results li {
    position: relative;
    padding: 9px 10px 9px 14px;
    border-radius: 3px;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: baseline;
    gap: 8px;
    cursor: pointer;
    transition: background var(--motion-tap), color var(--motion-tap);
  }

  .cmdk__cmd-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    font-weight: 500;
  }

  .cmdk__cmd-sep {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-soft);
    opacity: 0.6;
  }

  .cmdk__cmd-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-ink-soft);
    line-height: 1.3;
  }

  .cmdk__results li[data-cmd-disabled] {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .cmdk__results li[data-cmd-disabled] .cmdk__cmd-label,
  .cmdk__results li[data-cmd-disabled] .cmdk__cmd-desc {
    text-decoration: line-through;
    text-decoration-color: rgba(74, 81, 89, 0.4);
    text-decoration-thickness: 1px;
  }

  .cmdk__results li.is-active,
  .cmdk__results li:hover {
    background: var(--color-paper-shade);
    /* Inset accent rule on the left edge so the active row reads as
       a struck plate row, mirroring the SectionHeader underline. */
    box-shadow: inset 2px 0 0 var(--color-accent);
  }

  .cmdk__results li.is-active .cmdk__cmd-label,
  .cmdk__results li:hover .cmdk__cmd-label {
    color: var(--color-accent);
  }

  .cmdk__results li[data-cmd-disabled].is-active,
  .cmdk__results li[data-cmd-disabled]:hover {
    background: transparent;
    box-shadow: none;
  }

  .cmdk__hint {
    margin: 8px 0 0;
    padding: 8px 0 0;
    border-top: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    text-align: right;
    min-height: 1em;
  }

  .cmdk__keys {
    margin: 4px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    text-align: right;
    opacity: 0.7;
  }

  .cmdk__keys kbd {
    font-family: inherit;
    font-size: 9.5px;
    color: var(--color-ink);
    background: var(--color-paper-shade);
    padding: 1px 5px;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
    margin: 0 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cmdk__veil,
    .cmdk__panel {
      animation: none;
    }
  }
</style>
