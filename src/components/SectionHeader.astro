---
interface Props {
  num: string;
  title: string;
  dek?: string;
  id?: string;
  total?: string;
  dekWide?: boolean;
}

const { num, title, dek, id, total = "06", dekWide = false } = Astro.props;
const slugId = id ?? title.toLowerCase().replace(/\s+/g, "-");

// Folio reads as a running head: "PROJECTS · 02 / 06". Stronger
// print-tradition feel than the bare "§02 / 06" we had before.
const folioName = title.toUpperCase();

// Underline width drifts with section number (32px → 56px across §01-§06).
// Subtle progression so the rhythm feels authored rather than templated.
const underlineWidth = 32 + (parseInt(num, 10) - 1) * 5;
---

<header id={slugId} class="section-header">
  <div class="row">
    <p class="prefix">
      <span class="num">§{num}</span>
      <span class="bullet">·</span>
      <span class="label">{title}</span>
    </p>
    <span class="folio" aria-hidden="true">
      <span class="folio-name">{folioName}</span>
      <span class="folio-sep" aria-hidden="true">·</span>
      <span class="folio-count">{num} / {total}</span>
    </span>
  </div>
  {dek && <p class={`dek ${dekWide ? "dek--wide" : ""}`}>{dek}</p>}
  <span
    class="underline"
    aria-hidden="true"
    style={`--underline-w: ${underlineWidth}px;`}
  ></span>
</header>

<style>
  .section-header {
    margin-block: 96px 32px;
  }

  @media (min-width: 768px) {
    .section-header {
      margin-block: 144px 40px;
    }
  }

  .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
  }

  .prefix {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin: 0;
  }

  .num,
  .bullet {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(28px, 4vw, 44px);
    color: var(--color-ink);
    line-height: 1.05;
  }

  .folio {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    /* Lined + tabular figures so the count "02 / 06" stays a grid. */
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .folio-sep {
    opacity: 0.55;
  }

  .folio-count {
    color: var(--color-ink);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    /* On the narrowest phones the running-head treatment can crowd
       the title; collapse the section name and keep just the count. */
    .folio-name,
    .folio-sep {
      display: none;
    }
  }

  .dek {
    margin: 14px 0 0;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.6;
    color: var(--color-ink-soft);
    max-width: 64ch;
    text-wrap: pretty;
  }

  .dek--wide {
    max-width: 80ch;
  }

  .underline {
    display: block;
    margin-top: 16px;
    /* Underline width drifts with section number so §01 → §06 grow
       progressively. CSS-var driven; falls back to 32px if unset. */
    width: var(--underline-w, 32px);
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    transform-origin: left center;
  }

  /* Page-load entry: title and dek rise + fade; underline draws across
     from origin: left, like an inked rule pulled with a straightedge.
     CSS-only — most visitors see sections in the order they appear, and
     this plays once at load. */
  @keyframes sectionHeaderRise {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes sectionHeaderUnderline {
    from {
      opacity: 0;
      transform: scaleX(0);
    }
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  .row,
  .dek {
    animation: sectionHeaderRise var(--motion-reveal) both;
  }

  .underline {
    animation: sectionHeaderUnderline var(--motion-reveal) both;
    animation-delay: 160ms;
  }

  .row {
    animation-delay: 0ms;
  }

  .dek {
    animation-delay: 80ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .row,
    .dek,
    .underline {
      animation: none;
    }
  }
</style>
