---
---

<a class="sketchbook" href="/world/" aria-label="Step inside the studio">
  <span class="sketchbook__glyph" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="22" height="22" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
      <!-- Door frame -->
      <path d="M7 27 V6 Q7 4 9 4 H23 Q25 4 25 6 V27" />
      <!-- Door open angle (slightly ajar) -->
      <path d="M7 27 H25" />
      <!-- Door handle -->
      <circle cx="22" cy="16" r="0.9" fill="currentColor" />
      <!-- Inviting peek of light -->
      <path d="M11 8 H21" stroke-width="0.7" opacity="0.55" />
      <path d="M11 12 H19" stroke-width="0.7" opacity="0.45" />
      <path d="M11 16 H21" stroke-width="0.7" opacity="0.55" />
    </svg>
  </span>
  <span class="sketchbook__text">
    <span class="sketchbook__hint">step inside</span>
    <span class="sketchbook__label">the studio</span>
  </span>
  <span class="sketchbook__arrow" aria-hidden="true">↘</span>
</a>

<style>
  .sketchbook {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px 10px 13px;
    /* Default: emerald-on-paper, but quieter than the hero PhD pill so the
       hero CTA wins the first fold. Halo + pulse stay, just dialled back. */
    background: var(--color-accent);
    border: 1.5px solid var(--color-accent);
    border-radius: 999px;
    color: var(--color-paper);
    text-decoration: none;
    min-height: 44px;
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.06),
      0 10px 24px -12px rgba(14, 83, 71, 0.4);
    transition:
      transform 240ms cubic-bezier(.22,.72,.16,1),
      background 240ms ease-out,
      color 240ms ease-out,
      border-color 240ms ease-out,
      box-shadow 240ms ease-out;
  }

  /* Pulsing halo ring (visible at rest, slow + restrained) */
  .sketchbook::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 1.2px solid var(--color-accent);
    opacity: 0.4;
    pointer-events: none;
    animation: sketchbook-halo 5.4s ease-out infinite;
  }

  .sketchbook:hover,
  .sketchbook:focus-visible {
    transform: translateY(-3px) scale(1.03);
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-paper);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.08),
      0 22px 38px -12px rgba(15, 20, 23, 0.55);
  }

  .sketchbook:hover .sketchbook__hint,
  .sketchbook:focus-visible .sketchbook__hint {
    color: rgba(245, 239, 226, 0.78);
  }

  .sketchbook:hover .sketchbook__arrow,
  .sketchbook:focus-visible .sketchbook__arrow {
    transform: translate(3px, -3px);
  }

  .sketchbook__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: inherit;
  }

  .sketchbook__text {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    text-align: left;
  }

  .sketchbook__hint {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 239, 226, 0.85);
    margin-bottom: 5px;
    transition: color 240ms ease-out;
  }

  .sketchbook__label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    line-height: 1;
  }

  .sketchbook__arrow {
    display: inline-block;
    font-size: 15px;
    line-height: 1;
    transition: transform 240ms cubic-bezier(.22,.72,.16,1);
  }

  /* Idle: gentle breathing pulse — restrained so the hero PhD pill keeps focus */
  @keyframes sketchbook-breathe {
    0%, 100% {
      box-shadow:
        0 1px 0 rgba(15, 20, 23, 0.06),
        0 10px 24px -12px rgba(14, 83, 71, 0.4);
    }
    50% {
      box-shadow:
        0 1px 0 rgba(15, 20, 23, 0.06),
        0 14px 30px -10px rgba(14, 83, 71, 0.5);
    }
  }

  @keyframes sketchbook-halo {
    0%   { opacity: 0.45; inset: -2px;  border-width: 1.2px; }
    70%  { opacity: 0;    inset: -14px; border-width: 0.4px; }
    100% { opacity: 0;    inset: -14px; border-width: 0.4px; }
  }

  .sketchbook {
    animation: sketchbook-breathe 5.4s ease-in-out infinite;
  }

  @media (max-width: 720px) {
    /* Compact icon-only CTA on phones so the fixed pill doesn't obscure
       running copy mid-scroll. Tap target stays well above 44 px. */
    .sketchbook {
      padding: 13px;
      bottom: 18px;
      right: 18px;
      gap: 0;
      box-shadow:
        0 1px 0 rgba(15, 20, 23, 0.06),
        0 12px 26px -10px rgba(14, 83, 71, 0.55);
    }
    .sketchbook__text,
    .sketchbook__arrow {
      display: none;
    }
    .sketchbook__glyph {
      width: 24px;
      height: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sketchbook,
    .sketchbook::before {
      animation: none;
    }
    .sketchbook {
      transition: none;
    }
    .sketchbook:hover,
    .sketchbook:focus-visible {
      transform: none;
    }
  }
</style>
