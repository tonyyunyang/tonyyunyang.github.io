---
---

<a class="sketchbook" href="/world/" aria-label="Step inside the studio">
  <span class="sketchbook__glyph" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="22" height="22" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
      <!-- Door frame -->
      <path d="M7 27 V6 Q7 4 9 4 H23 Q25 4 25 6 V27" />
      <!-- Door open angle (slightly ajar) -->
      <path d="M7 27 H25" />
      <!-- Door handle -->
      <circle cx="22" cy="16" r="0.9" fill="currentColor" />
      <!-- Inviting peek of light -->
      <path d="M11 8 H21" stroke-width="0.7" opacity="0.55" />
      <path d="M11 12 H19" stroke-width="0.7" opacity="0.45" />
      <path d="M11 16 H21" stroke-width="0.7" opacity="0.55" />
    </svg>
  </span>
  <span class="sketchbook__text">
    <span class="sketchbook__hint">step inside</span>
    <span class="sketchbook__label">the studio</span>
  </span>
  <span class="sketchbook__arrow" aria-hidden="true">↘</span>
</a>

<style>
  .sketchbook {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px 10px 12px;
    background: var(--color-paper);
    border: 1.5px solid var(--color-ink);
    border-radius: 999px;
    color: var(--color-ink);
    text-decoration: none;
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 12px 28px -14px rgba(15, 20, 23, 0.32);
    transition:
      transform 240ms cubic-bezier(.22,.72,.16,1),
      background 240ms ease-out,
      color 240ms ease-out,
      border-color 240ms ease-out,
      box-shadow 240ms ease-out;
  }

  .sketchbook::before {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 1px dashed var(--color-hairline);
    opacity: 0;
    transition: opacity 240ms ease-out;
    pointer-events: none;
  }

  .sketchbook:hover,
  .sketchbook:focus-visible {
    transform: translateY(-3px);
    background: var(--color-accent);
    color: var(--color-paper);
    border-color: var(--color-accent);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.06),
      0 18px 32px -14px rgba(14, 83, 71, 0.45);
  }

  .sketchbook:hover::before,
  .sketchbook:focus-visible::before {
    opacity: 0.85;
  }

  .sketchbook:hover .sketchbook__hint,
  .sketchbook:focus-visible .sketchbook__hint {
    color: rgba(245, 239, 226, 0.75);
  }

  .sketchbook:hover .sketchbook__arrow,
  .sketchbook:focus-visible .sketchbook__arrow {
    transform: translate(2px, -2px);
  }

  .sketchbook__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: inherit;
  }

  .sketchbook__text {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    text-align: left;
  }

  .sketchbook__hint {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-bottom: 4px;
    transition: color 240ms ease-out;
  }

  .sketchbook__label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    line-height: 1;
  }

  .sketchbook__arrow {
    display: inline-block;
    font-size: 14px;
    line-height: 1;
    transition: transform 240ms cubic-bezier(.22,.72,.16,1);
  }

  /* Idle gentle pulse so it's noticed (one breath every 4s) */
  @keyframes sketchbook-breathe {
    0%, 100% { box-shadow: 0 1px 0 rgba(15, 20, 23, 0.04), 0 12px 28px -14px rgba(15, 20, 23, 0.32); }
    50%      { box-shadow: 0 1px 0 rgba(15, 20, 23, 0.04), 0 14px 36px -10px rgba(14, 83, 71, 0.28); }
  }

  .sketchbook {
    animation: sketchbook-breathe 4.8s ease-in-out infinite;
  }

  @media (max-width: 720px) {
    .sketchbook {
      padding: 10px 14px 10px 10px;
    }
    .sketchbook__hint {
      display: none;
    }
    .sketchbook__label {
      font-size: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sketchbook {
      animation: none;
      transition: none;
    }
    .sketchbook:hover,
    .sketchbook:focus-visible {
      transform: none;
    }
  }
</style>
