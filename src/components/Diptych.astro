---
import siteConfig from "~/content/site.json";

// The two directions, stated plainly as a numbered pair. Two equal panels
// seated on one wordless "plinth" of layered strata (a broad foundation
// beneath both), with a large serif numeral marking each. No thesis band,
// no editorializing: just 1 and 2.
const d = siteConfig.diptych;
---

<section class="diptych" aria-label="Two directions">
  <header class="diptych__header">
    <span class="diptych__rule" aria-hidden="true"></span>
    <h2 class="diptych__heading">{d.heading}</h2>
    <span class="diptych__rule" aria-hidden="true"></span>
  </header>

  <div class="diptych__plate">
    <!-- The two directions, equal weight, each marked with a numeral. -->
    <div class="diptych__panels">
      {d.directions.map((dir) => (
        <article class="diptych__panel">
          <span class="diptych__num" aria-hidden="true">{dir.num}</span>
          <h3 class="diptych__title">{dir.title}</h3>
          <p class="diptych__blurb">{dir.blurb}</p>
        </article>
      ))}
    </div>

    <!-- The plinth: a wordless band of strata. The broad foundation beneath
         both directions, grounding the panels without naming any work. -->
    <div class="diptych__plinth" aria-hidden="true">
      <svg
        class="diptych__strata"
        viewBox="0 0 1000 80"
        preserveAspectRatio="none"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
      >
        <path d="M0 14 Q250 5 500 14 Q750 23 1000 14" stroke-width="1" opacity="0.5" />
        <path d="M0 30 Q250 21 500 30 Q750 39 1000 30" stroke-width="0.9" opacity="0.42" />
        <path d="M0 46 Q250 37 500 46 Q750 55 1000 46" stroke-width="0.7" opacity="0.34" />
        <path d="M0 61 Q250 53 500 61 Q750 69 1000 61" stroke-width="0.6" opacity="0.26" />
        <path d="M0 74 Q250 68 500 74 Q750 80 1000 74" stroke-width="0.5" opacity="0.18" />
      </svg>
    </div>
  </div>
</section>

<style>
  .diptych {
    max-width: var(--content-with-rail);
    margin: 80px auto 32px;
    padding: 24px;
  }

  /* ============ HEADER (rule · italic label · rule) ============ */

  .diptych__header {
    margin: 0 0 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }

  .diptych__rule {
    flex: 1 1 auto;
    max-width: 180px;
    height: 1px;
    background: var(--color-hairline);
  }

  .diptych__heading {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  /* ============ THE PLATE (one bordered print plate; hairline seams) ============ */

  .diptych__plate {
    display: grid;
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--color-hairline);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  /* ---- The two panels ---- */

  .diptych__panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-hairline);
    position: relative;
    z-index: 1;
    box-shadow: 0 7px 11px -8px rgba(15, 20, 23, 0.22);
  }

  .diptych__panel {
    background: var(--color-paper-shade);
    padding: clamp(28px, 3vw, 44px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 160ms ease-out;
  }

  .diptych__panel:hover {
    background: var(--color-paper);
  }

  /* The numeral: a large serif drop-figure, the plain "1" and "2". Sits
     just above the title as the panel's index and only visual mark. */
  .diptych__num {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(40px, 4.4vw, 60px);
    line-height: 0.9;
    color: var(--color-accent);
    letter-spacing: -0.01em;
  }

  .diptych__title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.1vw, 28px);
    line-height: 1.16;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .diptych__blurb {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 15.5px;
    line-height: 1.62;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  /* ---- The plinth (wordless foundation: layered strata only) ---- */

  .diptych__plinth {
    position: relative;
    background: var(--color-paper-shade);
    height: clamp(84px, 9vw, 108px);
    box-shadow: inset 0 8px 14px -10px rgba(15, 20, 23, 0.32);
    overflow: hidden;
  }

  .diptych__strata {
    position: absolute;
    inset: auto 0 0 0;
    width: 100%;
    height: 100%;
    color: var(--color-ink-soft);
    pointer-events: none;
  }

  /* ============ RESPONSIVE ============ */

  @media (max-width: 560px) {
    .diptych {
      margin-top: 56px;
    }
    .diptych__panels {
      grid-template-columns: 1fr;
    }
    .diptych__title {
      font-size: 22px;
    }
    .diptych__blurb {
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .diptych__panel {
      transition: none;
    }
  }
</style>
