---
import siteConfig from "~/content/site.json";
import Icon from "./Icon.astro";

// The Diptych: the convergence stated with geometry. Two equal panels (the
// two directions Tony has converged on, each with a hand-drawn sketch mark)
// seated on one wordless "plinth" of layered strata, a broad foundation
// beneath both bets, said without naming a single thing. A thesis band above
// carries the conviction once. Replaces the retired 8-card "research compass".
//
// Built from the same seam recipe ResearchThemes used: a grid with a hairline
// background showing through 1px gaps, so dividers are crisp print rules.
const d = siteConfig.diptych;
---

<section class="diptych" aria-label="Two directions">
  <header class="diptych__header">
    <span class="diptych__rule" aria-hidden="true"></span>
    <h2 class="diptych__heading">{d.heading}</h2>
    <span class="diptych__rule" aria-hidden="true"></span>
  </header>

  <div class="diptych__plate">
    <!-- Thesis band: the conviction, stated exactly once. -->
    <div class="diptych__thesis">
      <p class="diptych__thesis-lead">{d.thesis}</p>
      <p class="diptych__belief">{d.belief}</p>
    </div>

    <!-- The two converged directions, equal weight, each with a sketch mark. -->
    <div class="diptych__panels">
      {d.directions.map((dir) => (
        <article class="diptych__panel">
          <span class="diptych__panel-glyph" aria-hidden="true">
            <Icon name={dir.icon} size={dir.iconSize} strokeWidth={dir.iconStroke} />
          </span>
          <p class="diptych__kicker">{dir.kicker}</p>
          <h3 class="diptych__title">{dir.title}</h3>
          <p class="diptych__blurb">{dir.blurb}</p>
        </article>
      ))}
    </div>

    <!-- The plinth: a wordless band of strata. The broad foundation beneath
         both bets, grounding the panels without naming any specific work. -->
    <div class="diptych__plinth" aria-hidden="true">
      <svg
        class="diptych__strata"
        viewBox="0 0 1000 80"
        preserveAspectRatio="none"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
      >
        <path d="M0 14 Q250 5 500 14 Q750 23 1000 14" stroke-width="1" opacity="0.5" />
        <path d="M0 30 Q250 21 500 30 Q750 39 1000 30" stroke-width="0.9" opacity="0.42" />
        <path d="M0 46 Q250 37 500 46 Q750 55 1000 46" stroke-width="0.7" opacity="0.34" />
        <path d="M0 61 Q250 53 500 61 Q750 69 1000 61" stroke-width="0.6" opacity="0.26" />
        <path d="M0 74 Q250 68 500 74 Q750 80 1000 74" stroke-width="0.5" opacity="0.18" />
      </svg>
    </div>
  </div>
</section>

<style>
  .diptych {
    /* Match the rail width + rhythm the compass section used so the page
       cadence is unchanged. */
    max-width: var(--content-with-rail);
    margin: 80px auto 32px;
    padding: 24px;
  }

  /* ============ HEADER (reused furniture: rule · italic label · rule) ============ */

  .diptych__header {
    margin: 0 0 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }

  .diptych__rule {
    flex: 1 1 auto;
    max-width: 180px;
    height: 1px;
    background: var(--color-hairline);
  }

  .diptych__heading {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  /* ============ THE PLATE (one bordered print plate; hairline seams) ============ */

  .diptych__plate {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 1px;
    background: var(--color-hairline);
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
  }

  /* ---- Thesis band ---- */

  .diptych__thesis {
    background: var(--color-featured);
    padding: clamp(26px, 3.4vw, 42px) clamp(24px, 5vw, 72px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .diptych__thesis-lead {
    margin: 0;
    max-width: 62ch;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(18px, 1.75vw, 23px);
    line-height: 1.42;
    letter-spacing: -0.005em;
    color: var(--color-ink-soft);
    text-wrap: balance;
  }

  /* The belief: the one loud conviction, set apart as an emerald pull-line. */
  .diptych__belief {
    margin: 0;
    max-width: 30ch;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.3vw, 30px);
    line-height: 1.24;
    letter-spacing: -0.006em;
    color: var(--color-accent);
    text-wrap: balance;
  }

  /* ---- The two panels ---- */

  .diptych__panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-hairline);
    /* Cast a soft shadow downward onto the plinth so the two panels read as
       columns resting on a base, not a third stacked band. Clipped to the
       plate by its overflow:hidden, so only the seam onto the plinth shows. */
    position: relative;
    z-index: 1;
    box-shadow: 0 7px 11px -8px rgba(15, 20, 23, 0.22);
  }

  .diptych__panel {
    background: var(--color-paper-shade);
    padding: clamp(24px, 2.6vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 160ms ease-out;
  }

  .diptych__panel:hover {
    background: var(--color-paper);
  }

  .diptych__panel-glyph {
    color: var(--color-ink);
    height: 34px;
    display: flex;
    align-items: center;
    transition: color 160ms ease-out;
  }

  .diptych__panel:hover .diptych__panel-glyph {
    color: var(--color-accent);
  }

  /* Micro-interactions: the marks come alive when you visit a panel. Motion on
     intent only (hover), never constant, so the reading stays calm. The plane
     lifts and banks as if sent; the vessel hops as if filling. */
  .diptych__panel-glyph :global(.icon) {
    transition: transform 320ms cubic-bezier(0.22, 0.72, 0.16, 1);
    transform-origin: center;
  }

  .diptych__panel:hover :global(.icon-paper-plane) {
    transform: translate(3px, -4px) rotate(-7deg) scale(1.04);
  }

  .diptych__panel:hover :global(.icon-build-data) {
    transform: translateY(-3px) scale(1.05);
  }

  .diptych__kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .diptych__title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.1vw, 28px);
    line-height: 1.16;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .diptych__blurb {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 15.5px;
    line-height: 1.62;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  /* ---- The plinth (wordless foundation: layered strata only) ---- */

  .diptych__plinth {
    position: relative;
    background: var(--color-paper-shade);
    height: clamp(84px, 9vw, 108px);
    /* A soft inset shadow at the top so the panels above read as resting ON
       the plinth like load-bearing stone (no new color: low-alpha ink). */
    box-shadow: inset 0 8px 14px -10px rgba(15, 20, 23, 0.32);
    overflow: hidden;
  }

  .diptych__strata {
    position: absolute;
    inset: auto 0 0 0;
    width: 100%;
    height: 100%;
    color: var(--color-ink-soft);
    pointer-events: none;
  }

  /* ============ RESPONSIVE ============ */

  /* Phone: panels stack. The plate's hairline gaps keep them visually seated
     on the plinth, so the bottom-to-top "standing on" read survives. */
  @media (max-width: 560px) {
    .diptych {
      margin-top: 56px;
    }
    .diptych__panels {
      grid-template-columns: 1fr;
    }
    .diptych__title {
      font-size: 22px;
    }
    .diptych__blurb {
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .diptych__panel,
    .diptych__panel-glyph :global(.icon) {
      transition: none;
    }
    .diptych__panel:hover :global(.icon-paper-plane),
    .diptych__panel:hover :global(.icon-build-data) {
      transform: none;
    }
  }
</style>
