---
import siteConfig from "~/content/site.json";
import Icon from "./Icon.astro";

const card = siteConfig.businessCard;

// Split "Open to research · academia or industry" on the middle dot so we
// can render the two phrases as discrete spans. This lets the mobile CSS
// stack them without ever wrapping mid-phrase.
const [lookingLabel, lookingWhen] = card.looking
  .split(/\s*·\s*/)
  .map((s) => s.trim());
---

<div class="card">
  <!-- Subtle paper plate background -->
  <svg class="card__plate" viewBox="0 0 800 460" aria-hidden="true" preserveAspectRatio="none">
    <defs>
      <pattern id="cardHatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(35)">
        <line x1="0" y1="0" x2="0" y2="6" stroke="#0F1417" stroke-width="0.4" opacity="0.5" />
      </pattern>
    </defs>
    <!-- Outer dashed frame -->
    <rect x="6" y="6" width="788" height="448" fill="none" stroke="#0F1417" stroke-width="0.6" stroke-dasharray="3 4" opacity="0.5" />
    <!-- Inner solid frame -->
    <rect x="14" y="14" width="772" height="432" fill="none" stroke="#0F1417" stroke-width="1.4" />
    <!-- Hatched corners (engraving plate flair) -->
    <rect x="14" y="14" width="60" height="14" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="14" y="14" width="14" height="60" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="726" y="14" width="60" height="14" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="772" y="14" width="14" height="60" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="14" y="432" width="60" height="14" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="14" y="372" width="14" height="60" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="726" y="432" width="60" height="14" fill="url(#cardHatch)" opacity="0.55" />
    <rect x="772" y="372" width="14" height="60" fill="url(#cardHatch)" opacity="0.55" />
    <!-- Decorative top centerpiece (a printer's flourish) -->
    <g class="card__plate-flourish">
      <path d="M340 26 Q360 18 380 26 Q400 34 420 26 Q440 18 460 26" fill="none" stroke="#0F1417" stroke-width="0.7" />
      <circle cx="400" cy="26" r="2" fill="#0E5347" />
    </g>
    <!-- Bottom decorative line -->
    <path d="M14 422 H786" stroke="#0F1417" stroke-width="0.4" opacity="0.5" />
  </svg>

  <div class="card__content">
    <div class="card__top">
      <div class="card__head">
        <p class="card__looking">
          <span class="card__looking-mark" aria-hidden="true">
            <Icon name="spark" size={14} strokeWidth={1.4} />
          </span>
          <span class="card__looking-text">
            <span class="card__looking-label">{lookingLabel}</span>
            {lookingWhen && (
              <>
                <span class="card__looking-sep" aria-hidden="true">·</span>
                <span class="card__looking-when">{lookingWhen}</span>
              </>
            )}
          </span>
        </p>
        <h3 class="card__name">
          <span class="card__name-en">{card.name}</span>
          <span class="card__name-zh">{card.nameZh}</span>
        </h3>
        <p class="card__role">{card.role}</p>
        <p class="card__tagline">{card.tagline}</p>
      </div>
      <div class="card__crest" aria-hidden="true">
        <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <!-- Hand-drawn monogram crest TY -->
          <circle cx="40" cy="40" r="34" stroke-width="1.2" />
          <circle cx="40" cy="40" r="28" stroke-width="0.5" stroke-dasharray="1.6 2.4" opacity="0.55" />
          <text x="40" y="48" text-anchor="middle" font-family="EB Garamond, serif" font-style="italic" font-size="32" fill="currentColor" stroke="none">TY</text>
          <path d="M22 64 L40 70 L58 64" stroke-width="0.8" />
        </svg>
      </div>
    </div>

    <div class="card__divider" aria-hidden="true">
      <span class="card__divider-line"></span>
      <span class="card__divider-mark">·</span>
      <span class="card__divider-line"></span>
    </div>

    <div class="card__bottom">
      <ul class="card__contact">
        <li>
          <a href={`mailto:${siteConfig.contact.email}`}>
            <Icon name="envelope" size={16} strokeWidth={1.4} />
            <span>{siteConfig.contact.email}</span>
          </a>
        </li>
        <li>
          <a href={siteConfig.contact.scholar} target="_blank" rel="noopener noreferrer">
            <Icon name="scholar" size={16} strokeWidth={1.4} />
            <span>google scholar</span>
          </a>
        </li>
        <li>
          <a href={siteConfig.contact.github} target="_blank" rel="noopener noreferrer">
            <Icon name="branch" size={16} strokeWidth={1.4} />
            <span>github / tonyyunyang</span>
          </a>
        </li>
        <li>
          <a href={siteConfig.contact.cv.en} target="_blank" rel="noopener noreferrer">
            <Icon name="document" size={16} strokeWidth={1.4} />
            <span>curriculum vitae · english · pdf</span>
          </a>
        </li>
        <li>
          <a href={siteConfig.contact.cv.zh} target="_blank" rel="noopener noreferrer">
            <Icon name="document" size={16} strokeWidth={1.4} />
            <span>curriculum vitae · 中文 · pdf</span>
          </a>
        </li>
      </ul>

      <div class="card__meta">
        <div class="card__meta-block">
          <p class="card__meta-label">
            <Icon name="pin" size={12} strokeWidth={1.4} />
            <span>based in</span>
          </p>
          <ul class="card__meta-list">
            {card.locations.map((loc) => <li>{loc}</li>)}
          </ul>
        </div>
        <div class="card__meta-block">
          <p class="card__meta-label">
            <Icon name="globe" size={12} strokeWidth={1.4} />
            <span>languages</span>
          </p>
          <ul class="card__meta-list">
            {card.languages.map((lang) => (
              <li>
                <span class="card__lang-name">{lang.lang}</span>
                <span class="card__lang-level">{lang.level}</span>
                {lang.note && <span class="card__lang-note">{lang.note}</span>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <p class="card__signature">
      <span class="card__signature-line" aria-hidden="true"></span>
      <span class="card__signature-text">signed · T.</span>
    </p>
  </div>
</div>

<style>
  .card {
    position: relative;
    margin: 32px 0 16px;
    padding: 36px 40px 28px;
    background: var(--color-paper-shade);
    border-radius: var(--radius-card);
    overflow: hidden;
    color: var(--color-ink);
  }

  .card__plate {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-ink);
    opacity: 0.85;
    pointer-events: none;
  }

  .card__content {
    position: relative;
    z-index: 1;
  }

  .card__top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: start;
  }

  /* Echoes the hero's "Open to research" pill: same spark mark, same
     emerald stadium, so the repeated CTA reads as one hand. It is a
     status badge here (no arrow) since the card already sits in §06. */
  .card__looking {
    margin: 0 0 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-paper);
    border: 1.4px solid var(--color-accent);
    padding: 9px 15px 8px;
    border-radius: 999px;
    max-width: 100%;
    box-shadow: 0 1px 0 rgba(14, 83, 71, 0.06), 0 6px 18px -10px rgba(14, 83, 71, 0.4);
  }

  .card__looking-mark {
    color: var(--color-accent);
    flex: 0 0 auto;
  }

  .card__looking-text {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    min-width: 0;
  }

  .card__looking-label,
  .card__looking-when {
    white-space: nowrap;
  }

  .card__looking-sep {
    opacity: 0.55;
  }

  .card__name {
    /* Bottom margin opens up so the role line "INDEPENDENT AI RESEARCHER"
       doesn't crowd the cap of the name. 6 px read as glued together at
       the desktop scale. */
    margin: 4px 0 14px;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(34px, 4vw, 48px);
    line-height: 1;
    letter-spacing: -0.005em;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .card__name-en {
    /* Upright EB Garamond, matching the hero wordmark exactly (same
       name, one slant). The hero comment notes upright reads "elegant
       + readable, not fancy"; the card follows. */
    font-style: normal;
  }

  .card__name-zh {
    /* Match the Hero treatment: LXGW WenKai (humanist calligraphic
       Chinese face) at weight 500, with the same caps-align nudge so
       the Chinese sits visually flush with the Latin name. Size stays
       slightly larger here (0.6em vs Hero's 0.44em) because the card's
       parent name is much smaller. */
    font-family: var(--font-display-zh);
    font-weight: 500;
    font-style: normal;
    font-size: 0.6em;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
    transform: translateY(-0.04em);
  }

  .card__role {
    margin: 0 0 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    line-height: 1.25;
  }

  .card__tagline {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16.5px;
    font-weight: 500;
    color: var(--color-ink);
    opacity: 0.88;
  }

  .card__crest {
    color: var(--color-accent);
    width: 88px;
    height: 88px;
  }

  .card__crest svg {
    width: 100%;
    height: 100%;
  }

  .card__divider {
    margin: 24px 0 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card__divider-line {
    flex: 1;
    height: 1px;
    background: var(--color-hairline);
  }

  .card__divider-mark {
    font-family: var(--font-mono);
    color: var(--color-ink-soft);
    font-size: 12px;
  }

  .card__bottom {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .card__contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card__contact a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 180ms ease-out, transform 200ms ease-out;
    will-change: transform;
  }

  .card__contact a:hover {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .card__contact a {
      transition: color 180ms ease-out;
    }
    .card__contact a:hover {
      transform: none;
    }
  }

  .card__meta {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .card__meta-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card__meta-label {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .card__meta-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14.5px;
    color: var(--color-ink);
  }

  .card__meta-list li {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.35;
  }

  .card__lang-name {
    font-weight: 500;
  }

  .card__lang-level {
    color: var(--color-ink);
  }

  .card__lang-note {
    font-size: 12.5px;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .card__signature {
    margin: 24px 0 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-ink-soft);
  }

  .card__signature-line {
    flex: 1;
    height: 1px;
    background: var(--color-hairline);
  }

  .card__signature-text {
    white-space: nowrap;
  }

  /* One-shot entrance animation when the card mounts. Each direct child of
     .card__content fades + rises 8px in sequence. CSS-only, no JS observer. */
  @keyframes cardReveal {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card__content > * {
    animation: cardReveal 700ms ease-out both;
  }

  .card__content > *:nth-child(1) {
    animation-delay: 0ms;
  }
  .card__content > *:nth-child(2) {
    animation-delay: 120ms;
  }
  .card__content > *:nth-child(3) {
    animation-delay: 240ms;
  }
  .card__content > *:nth-child(4) {
    animation-delay: 360ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .card__content > * {
      animation: none;
    }
  }

  @media (max-width: 720px) {
    /* Bigger padding-bottom: the SVG plate's inner solid border lives at
       viewBox y=446 (out of 460), i.e. ~3% of the card's height from the
       bottom. With only 22 px of bottom padding the languages caption was
       reaching past that border line into the dead zone. 56 px keeps the
       last text line and the signature row both safely above the border. */
    .card {
      padding: 28px 22px 56px;
    }
    /* Hide on mobile: the pill's "RESEARCH" was widening into this
       printer's flourish at the top centerline. */
    .card__plate-flourish {
      display: none;
    }
    /* Hide the TY monogram crest on mobile. In single-column flow it
       sits as an orphan row between the tagline and the divider, which
       reads as awkward dead space. The crest is decorative — the card
       reads cleanly without it on phones. */
    .card__crest {
      display: none;
    }
    .card__top {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .card__bottom {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .card__divider {
      margin: 22px 0 20px;
    }
    .card__signature {
      margin-top: 20px;
    }
    .card__name {
      margin: 6px 0 10px;
      flex-direction: column;
      gap: 4px;
      font-size: clamp(32px, 8vw, 40px);
    }
    .card__name-zh {
      font-size: 0.55em;
    }
    .card__role {
      font-size: 10.5px;
      letter-spacing: 0.14em;
      margin-bottom: 12px;
      line-height: 1.3;
    }
    .card__tagline {
      font-size: 15.5px;
    }
    /* Pill: refined rounded button shape (12 px radius) sized to its
       content. The 18 px radius from before still read as a stretched
       stadium against the stacked label / when. 12 px gives a cleaner
       "tag" feel that pairs with the printer's plate aesthetic. */
    .card__looking {
      margin: 0 0 16px;
      align-items: flex-start;
      padding: 9px 14px 8px;
      border-radius: 12px;
      font-size: 10.5px;
      letter-spacing: 0.14em;
    }
    .card__looking-mark {
      transform: translateY(2px);
    }
    .card__looking-text {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }
    .card__looking-sep {
      display: none;
    }
    .card__looking-when {
      font-size: 9.5px;
      color: var(--color-ink-soft);
      letter-spacing: 0.12em;
    }
    /* Bigger contact-list type on mobile — 12 px mono read too small
       relative to the rest of the card. 13.5 px improves scannability
       and tap comfort on touchscreens. */
    .card__contact a {
      font-size: 13.5px;
      gap: 12px;
    }
    .card__contact {
      gap: 10px;
    }
    /* Tighten the meta blocks so "BASED IN" and "LANGUAGES" stack with
       intentional spacing rather than the desktop's 18 px gap. */
    .card__meta {
      gap: 16px;
    }
    .card__meta-list {
      font-size: 14px;
    }
    .card__lang-note {
      font-size: 12px;
      line-height: 1.4;
    }
  }
</style>
