---
import siteConfig from "~/content/site.json";
import PillLink from "./PillLink.astro";
import Icon from "./Icon.astro";
---

<section id="currently" class="intro">
  <div class="intro__head">
    <figure class="intro__photo">
      <img
        src="/profile/Profile.jpg"
        alt="Portrait of Tony Yang"
        loading="eager"
        width="280"
        height="280"
      />
      <span class="intro__photo-corner intro__photo-corner--tl" aria-hidden="true"></span>
      <span class="intro__photo-corner intro__photo-corner--tr" aria-hidden="true"></span>
      <span class="intro__photo-corner intro__photo-corner--bl" aria-hidden="true"></span>
      <span class="intro__photo-corner intro__photo-corner--br" aria-hidden="true"></span>
    </figure>
    <div class="intro__text">
      <p class="intro__eyebrow">
        <span class="intro__eyebrow-num">§00</span>
        <span class="intro__eyebrow-bullet">·</span>
        <span class="intro__eyebrow-label">Currently</span>
      </p>

      <p class="intro__opening">
        <span class="intro__opening-mark" aria-hidden="true">
          <Icon name="sparkles" size={18} strokeWidth={1.2} />
        </span>
        <span class="intro__opening-text">{siteConfig.openingHeadline}</span>
      </p>
      <p class="intro__opening-body">{siteConfig.openingBody}</p>

      <p class="intro__currently-label">{siteConfig.currentlyHeadline}</p>
      <p class="intro__currently">{siteConfig.currently}</p>

      <div class="intro__pills">
        <PillLink href={`mailto:${siteConfig.contact.email}`} label="email" icon="envelope" />
        <PillLink href={siteConfig.contact.scholar} label="scholar" icon="scholar" />
        <PillLink href={siteConfig.contact.github} label="github" icon="branch" />
        <PillLink href={siteConfig.contact.cv} label="cv" icon="document" />
      </div>
    </div>
  </div>
</section>

<style>
  .intro {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 24px;
  }

  .intro__head {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 720px) {
    .intro__head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .intro__photo {
    position: relative;
    margin: 0;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-paper-shade);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 14px 30px -18px rgba(15, 20, 23, 0.18);
  }

  .intro__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    display: block;
    border-radius: 4px;
  }

  /* Hand-drawn corner crops, like a printed plate or a polaroid */
  .intro__photo-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 1.4px solid var(--color-ink);
    pointer-events: none;
  }

  .intro__photo-corner--tl {
    top: 8px;
    left: 8px;
    border-right: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--tr {
    top: 8px;
    right: 8px;
    border-left: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--bl {
    bottom: 8px;
    left: 8px;
    border-right: 0;
    border-top: 0;
  }

  .intro__photo-corner--br {
    bottom: 8px;
    right: 8px;
    border-left: 0;
    border-top: 0;
  }

  .intro__eyebrow {
    margin: 0 0 18px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .intro__eyebrow-num,
  .intro__eyebrow-bullet {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__eyebrow-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--color-ink);
    line-height: 1;
  }

  .intro__opening {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.18;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .intro__opening-mark {
    color: var(--color-accent);
    flex: 0 0 auto;
    transform: translateY(2px);
  }

  .intro__opening-text {
    flex: 1 1 auto;
  }

  .intro__opening-body {
    margin: 0 0 28px;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 60ch;
  }

  .intro__currently-label {
    margin: 0 0 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__currently {
    margin: 0;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }

  .intro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }
</style>
