---
import siteConfig from "~/content/site.json";
import PillLink from "./PillLink.astro";
import Icon from "./Icon.astro";

// §00 mirrors the SectionHeader structure (prefix · folio · underline)
// so the opening section reads as part of the same numbered series as
// §01-§06 instead of a small tucked-in eyebrow.
//
// Layout sits in three regions:
//   A · top     — 2-col: photo (left) + headline + opening body (right)
//   B · day-to-day — full-width: DAY-TO-DAY label + extended bio prose
//   C · contact — 2-col: email row (left) + pill links (right)
---

<section id="currently" class="intro">
  <header class="intro__head">
    <div class="intro__head-row">
      <p class="intro__head-prefix">
        <span class="intro__head-num">§00</span>
        <span class="intro__head-bullet">·</span>
        <span class="intro__head-label">Currently</span>
      </p>
      <span class="intro__head-folio" aria-hidden="true">
        <span class="intro__head-folio-name">CURRENTLY</span>
        <span class="intro__head-folio-sep">·</span>
        <span class="intro__head-folio-count">00 / 06</span>
      </span>
    </div>
    <span class="intro__head-rule" aria-hidden="true"></span>
  </header>

  <div class="intro__body">
    <!-- Region A · top -->
    <div class="intro__top">
      <figure class="intro__figure">
        <div class="intro__photo">
          <img
            src="/profile/Profile.jpg"
            alt="Portrait of Tony Yang"
            loading="eager"
            width="300"
            height="300"
          />
          <span class="intro__photo-corner intro__photo-corner--tl" aria-hidden="true"></span>
          <span class="intro__photo-corner intro__photo-corner--tr" aria-hidden="true"></span>
          <span class="intro__photo-corner intro__photo-corner--bl" aria-hidden="true"></span>
          <span class="intro__photo-corner intro__photo-corner--br" aria-hidden="true"></span>
        </div>
        <figcaption class="intro__caption">
          <span class="intro__caption-meta">PORTRAIT · 2026</span>
          <span class="intro__caption-name">Tony Yang <span class="intro__caption-zh">杨童耘</span></span>
        </figcaption>
      </figure>

      <div class="intro__lede">
        <p class="intro__opening">
          <span class="intro__opening-mark" aria-hidden="true">
            <Icon name="sparkles" size={18} strokeWidth={1.2} />
          </span>
          <span class="intro__opening-text">{siteConfig.openingHeadline}</span>
        </p>
        <p class="intro__opening-body">{siteConfig.openingBody}</p>
      </div>
    </div>

    <!-- Region B · day-to-day (full-width) -->
    <div class="intro__day-to-day">
      <p class="intro__currently-label">{siteConfig.currentlyHeadline}</p>
      <p class="intro__currently">{siteConfig.currently}</p>
    </div>

    <!-- Region C · contact (2-col: email-text left, pill links right) -->
    <div class="intro__contact-grid">
      <p class="intro__email-row">
        <span class="intro__email-label">Email</span>
        <a class="intro__email-addr" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
      </p>
      <div class="intro__pills">
        <PillLink href={`mailto:${siteConfig.contact.email}`} label="email" icon="envelope" />
        <PillLink href={siteConfig.contact.scholar} label="scholar" icon="scholar" />
        <PillLink href={siteConfig.contact.github} label="github" icon="branch" />
        <PillLink href={siteConfig.contact.cv.en} label="cv · en" icon="document" />
        <PillLink href={siteConfig.contact.cv.zh} label="cv · 中文" icon="document" />
      </div>
    </div>
  </div>
</section>

<style>
  .intro {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 24px;
  }

  /* ============ Section head (§00) — mirrors SectionHeader so the
       opening section reads architecturally like §01-§06 ============ */

  .intro__head {
    margin-bottom: 36px;
  }

  .intro__head-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    flex-wrap: wrap;
  }

  .intro__head-prefix {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__head-num {
    color: var(--color-accent);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .intro__head-bullet {
    opacity: 0.55;
  }

  .intro__head-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: none;
    color: var(--color-ink);
  }

  .intro__head-folio {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .intro__head-folio-sep {
    opacity: 0.55;
  }

  .intro__head-folio-count {
    color: var(--color-ink);
    font-weight: 500;
  }

  .intro__head-rule {
    display: block;
    margin-top: 16px;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    transform-origin: left center;
  }

  @media (max-width: 480px) {
    .intro__head-folio-name,
    .intro__head-folio-sep {
      display: none;
    }
    .intro__head-label {
      font-size: 26px;
    }
  }

  /* ============ Body (vertical stack of three regions) ============ */

  .intro__body {
    display: grid;
    gap: 36px;
  }

  /* ============ Region A · top — photo + lede in 2-col ============ */

  .intro__top {
    display: grid;
    grid-template-columns: clamp(240px, 26vw, 300px) minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 720px) {
    .intro__top {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .intro__figure {
    margin: 0;
    width: 100%;
  }

  @media (max-width: 720px) {
    .intro__figure {
      width: clamp(240px, 74vw, 320px);
      margin-inline: auto;
    }
  }

  .intro__photo {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-paper-shade);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 14px 30px -18px rgba(15, 20, 23, 0.18);
  }

  .intro__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    display: block;
    border-radius: 4px;
    /* Photo renders at its natural color — no filter, no overlay. */
  }

  /* Hand-drawn corner crops, like a printed plate or a polaroid */
  .intro__photo-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 1.4px solid var(--color-ink);
    pointer-events: none;
  }

  .intro__photo-corner--tl {
    top: 8px;
    left: 8px;
    border-right: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--tr {
    top: 8px;
    right: 8px;
    border-left: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--bl {
    bottom: 8px;
    left: 8px;
    border-right: 0;
    border-top: 0;
  }

  .intro__photo-corner--br {
    bottom: 8px;
    right: 8px;
    border-left: 0;
    border-top: 0;
  }

  /* Photo caption: a small print-tradition colophon under the portrait. */
  .intro__caption {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 14px;
    text-align: left;
  }

  .intro__caption-meta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
  }

  .intro__caption-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--color-ink);
    line-height: 1.2;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .intro__caption-zh {
    font-family: var(--font-display-zh);
    font-style: normal;
    font-size: 0.9em;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
  }

  /* ============ Lede (right side of region A) ============ */

  .intro__lede {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .intro__opening {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.18;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 12px;
    text-wrap: balance;
  }

  .intro__opening-mark {
    color: var(--color-accent);
    flex: 0 0 auto;
    transform: translateY(2px);
  }

  .intro__opening-text {
    flex: 1 1 auto;
  }

  .intro__opening-body {
    margin: 0;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 60ch;
    text-wrap: pretty;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  /* ============ Region B · day-to-day (full-width) ============ */

  .intro__day-to-day {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .intro__currently-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__currently {
    margin: 0;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 68ch;
    text-wrap: pretty;
  }

  /* ============ Region C · contact grid (email left, pills right) ============

     Flex rather than grid so the email column takes its natural width
     and the pills get all the remaining room — that way a 5th pill
     never orphans onto a second line at desktop. On mobile the row
     wraps and stacks. */

  .intro__contact-grid {
    padding-top: 22px;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px 32px;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .intro__contact-grid {
      padding-top: 18px;
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .intro__email-row {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 0 1 auto;
    min-width: 0;
  }

  .intro__email-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__email-addr {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 83, 71, 0.35);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: color var(--motion-warm), border-color var(--motion-warm);
  }

  .intro__email-addr:hover,
  .intro__email-addr:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  .intro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    align-items: center;
    flex: 1 1 auto;
    min-width: 0;
  }

  @media (max-width: 720px) {
    .intro__pills {
      justify-content: flex-start;
    }
  }
</style>
