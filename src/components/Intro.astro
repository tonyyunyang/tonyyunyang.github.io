---
import siteConfig from "~/content/site.json";
import PillLink from "./PillLink.astro";
import Icon from "./Icon.astro";

// §00 mirrors the SectionHeader structure (prefix · folio · underline)
// so the opening section reads architecturally like §01-§06.
//
// Layout: portrait photo on the left fills the full height of the
// right-column content (which contains everything: headline, opening
// body, DAY-TO-DAY block, and the contact strip with email + pills).
// The photo's source is already 3253×3978 portrait, so the tall crop
// renders naturally with no obvious distortion.
---

<section id="currently" class="intro">
  <header class="intro__head">
    <div class="intro__head-row">
      <p class="intro__head-prefix">
        <span class="intro__head-num">§00</span>
        <span class="intro__head-bullet">·</span>
        <span class="intro__head-label">Currently</span>
      </p>
      <span class="intro__head-folio" aria-hidden="true">
        <span class="intro__head-folio-name">CURRENTLY</span>
        <span class="intro__head-folio-sep">·</span>
        <span class="intro__head-folio-count">00 / 06</span>
      </span>
    </div>
    <span class="intro__head-rule" aria-hidden="true"></span>
  </header>

  <div class="intro__layout">
    <figure class="intro__figure">
      <div class="intro__photo">
        <img
          src="/profile/Profile.jpg"
          alt="Portrait of Tony Yang"
          loading="eager"
          width="320"
          height="400"
        />
        <span class="intro__photo-corner intro__photo-corner--tl" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--tr" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--bl" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--br" aria-hidden="true"></span>
      </div>
    </figure>

    <div class="intro__content">
      <p class="intro__opening">
        <span class="intro__opening-mark" aria-hidden="true">
          <Icon name="sparkles" size={18} strokeWidth={1.2} />
        </span>
        <span class="intro__opening-text">{siteConfig.openingHeadline}</span>
      </p>
      <p class="intro__opening-body">{siteConfig.openingBody}</p>

      <div class="intro__day">
        <p class="intro__currently-label">{siteConfig.currentlyHeadline}</p>
        <p class="intro__currently">{siteConfig.currently}</p>
      </div>

      <div class="intro__contact-row">
        <p class="intro__email-row">
          <span class="intro__email-label">Email</span>
          <a class="intro__email-addr" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
        </p>
        <div class="intro__pills">
          <!-- Email lives in the row above (clickable). The pill set is
               the externally-linked profiles + CVs only, so there's no
               duplicate of the email and the four pills fit one row. -->
          <PillLink href={siteConfig.contact.scholar} label="scholar" icon="scholar" />
          <PillLink href={siteConfig.contact.github} label="github" icon="branch" />
          <PillLink href={siteConfig.contact.cv.en} label="cv · en" icon="document" />
          <PillLink href={siteConfig.contact.cv.zh} label="cv · 中文" icon="document" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 24px;
  }

  /* ============ Section head (§00) — mirrors SectionHeader ============ */

  .intro__head {
    margin-bottom: 36px;
  }

  .intro__head-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    flex-wrap: wrap;
  }

  .intro__head-prefix {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__head-num {
    color: var(--color-accent);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .intro__head-bullet {
    opacity: 0.55;
  }

  .intro__head-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: none;
    color: var(--color-ink);
  }

  .intro__head-folio {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums lining-nums;
  }

  .intro__head-folio-sep {
    opacity: 0.55;
  }

  .intro__head-folio-count {
    color: var(--color-ink);
    font-weight: 500;
  }

  .intro__head-rule {
    display: block;
    margin-top: 16px;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    transform-origin: left center;
  }

  @media (max-width: 480px) {
    .intro__head-folio-name,
    .intro__head-folio-sep {
      display: none;
    }
    .intro__head-label {
      font-size: 26px;
    }
  }

  /* ============ Layout: photo (left, fills column height) + content (right) ============ */

  .intro__layout {
    display: grid;
    grid-template-columns: clamp(260px, 26vw, 300px) minmax(0, 1fr);
    gap: 36px;
    /* stretch so the photo column matches the natural height of the
       content column on the right. The photo's flex:1 inside fills
       the column. */
    align-items: stretch;
  }

  @media (max-width: 720px) {
    .intro__layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  /* ============ Photo column ============ */

  .intro__figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .intro__photo {
    position: relative;
    flex: 1 1 auto;
    /* Floor so the photo never collapses if the right column is very
       short (e.g., reduced motion, narrow viewport, etc.). */
    min-height: 480px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-paper-shade);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 14px 30px -18px rgba(15, 20, 23, 0.18);
  }

  @media (max-width: 720px) {
    .intro__photo {
      /* On mobile we fall back to a portrait crop (4:5) and cap width
         so the photo doesn't dominate the narrow viewport. */
      aspect-ratio: 4 / 5;
      min-height: 0;
      width: clamp(260px, 80vw, 360px);
      margin-inline: auto;
    }
  }

  .intro__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Pull a touch above center so the face anchors the upper third
       of the photograph and the body fills the lower portion. */
    object-position: center 22%;
    display: block;
    border-radius: 4px;
  }

  /* Hand-drawn corner crops, like a printed plate or a polaroid */
  .intro__photo-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 1.4px solid var(--color-ink);
    pointer-events: none;
  }

  .intro__photo-corner--tl {
    top: 8px;
    left: 8px;
    border-right: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--tr {
    top: 8px;
    right: 8px;
    border-left: 0;
    border-bottom: 0;
  }

  .intro__photo-corner--bl {
    bottom: 8px;
    left: 8px;
    border-right: 0;
    border-top: 0;
  }

  .intro__photo-corner--br {
    bottom: 8px;
    right: 8px;
    border-left: 0;
    border-top: 0;
  }

  /* ============ Right column ============ */

  .intro__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  /* Opening headline. Upright EB Garamond 500 reads as a confident
     direct statement rather than a literary quote. The sparkle mark
     stays as a small print-tradition opener. */
  .intro__opening {
    margin: 0;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.28;
    letter-spacing: -0.005em;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 12px;
    text-wrap: balance;
  }

  .intro__opening-mark {
    color: var(--color-accent);
    flex: 0 0 auto;
    transform: translateY(2px);
  }

  .intro__opening-text {
    flex: 1 1 auto;
  }

  .intro__opening-body {
    margin: 0;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--color-ink);
    max-width: 60ch;
    text-wrap: pretty;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  /* DAY-TO-DAY block */

  .intro__day {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .intro__currently-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__currently {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-soft);
    max-width: 64ch;
    text-wrap: pretty;
  }

  /* Contact: email row stacked above the pill links so the pills get
     the full right-column width (plenty of room for all five). The
     hairline rule above the block separates it from the prose. */

  .intro__contact-row {
    margin-top: 4px;
    padding-top: 22px;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 720px) {
    .intro__contact-row {
      padding-top: 18px;
    }
  }

  .intro__email-row {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .intro__email-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__email-addr {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 83, 71, 0.35);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: color var(--motion-warm), border-color var(--motion-warm);
  }

  .intro__email-addr:hover,
  .intro__email-addr:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  .intro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-start;
    align-items: center;
  }

  /* Tighter pill chrome inside the §00 contact row so all four
     profile/CV pills fit on a single row inside the narrower right
     column. Tap target stays at 40px (still comfortable on touch),
     padding eased from 12/16 → 10/13. */
  .intro__pills :global(.pill) {
    padding: 10px 13px;
    min-height: 40px;
    font-size: 10.5px;
    letter-spacing: 0.09em;
  }
</style>
