---
import siteConfig from "~/content/site.json";
import PillLink from "./PillLink.astro";
import SectionHeader from "./SectionHeader.astro";

// §00, "A letter from the desk". A short personal note set as one unified
// block: every paragraph is the same face and size (Inter), and a bold
// lead-in phrase at the head of each paragraph does the guiding, so the
// three beats (the turn, the belief, the day-to-day) read as one voice
// rather than three differently-styled boxes.
const letter = siteConfig.letter;
---

<section class="intro" aria-label="Currently">
  <SectionHeader num="00" title="A letter from the desk" id="currently" icon="pen" />

  <div class="intro__layout">
    <figure class="intro__figure">
      <div class="intro__photo">
        <img
          src="/profile/Profile.jpg"
          alt="Portrait of Tony Yang"
          loading="eager"
          width="320"
          height="400"
        />
        <span class="intro__photo-corner intro__photo-corner--tl" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--tr" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--bl" aria-hidden="true"></span>
        <span class="intro__photo-corner intro__photo-corner--br" aria-hidden="true"></span>
      </div>
    </figure>

    <div class="intro__content">
      <div class="intro__letter">
        {letter.paragraphs.map((p) => (
          <p class="intro__para">
            <strong class="intro__lead">{p.lead}</strong>{p.rest}
          </p>
        ))}
      </div>

      <div class="intro__contact-row">
        <p class="intro__email-row">
          <span class="intro__email-label">Email</span>
          <a class="intro__email-addr" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
        </p>
        <div class="intro__pills">
          <!-- Email lives in the row above (clickable). The pill set is
               the externally-linked profiles + CVs only, so there's no
               duplicate of the email and the four pills fit one row. -->
          <PillLink href={siteConfig.contact.scholar} label="scholar" icon="scholar" />
          <PillLink href={siteConfig.contact.github} label="github" icon="branch" />
          <PillLink href={siteConfig.contact.cv.en} label="cv · en" icon="document" />
          <PillLink href={siteConfig.contact.cv.zh} label="cv · 中文" icon="document" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro {
    /* §00 uses the wider rail width (matches the hero) so the
       photo + prose + contact strip have room to breathe. The
       other §-numbered sections stay at --content-max. */
    max-width: var(--content-with-rail);
    margin-inline: auto;
    padding: 24px;
  }

  /* ============ Layout: photo (left) + content (right) ============ */

  .intro__layout {
    display: grid;
    grid-template-columns: clamp(320px, 28vw, 400px) minmax(0, 1fr);
    gap: 56px;
    align-items: center;
  }

  @media (max-width: 720px) {
    .intro__layout {
      grid-template-columns: 1fr;
      gap: 28px;
      align-items: start;
    }
  }

  /* ============ Photo column ============ */

  .intro__figure {
    margin: 0;
  }

  .intro__photo {
    position: relative;
    width: 100%;
    /* Native source ratio is 3253x3978 ≈ 5:6. */
    aspect-ratio: 5 / 6;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-paper-shade);
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 14px 30px -18px rgba(15, 20, 23, 0.18);
  }

  @media (max-width: 720px) {
    .intro__photo {
      aspect-ratio: 4 / 5;
      width: clamp(260px, 80vw, 360px);
      margin-inline: auto;
    }
  }

  .intro__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    border-radius: 4px;
  }

  /* Hand-drawn corner crops, like a printed plate or a polaroid */
  .intro__photo-corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 1.4px solid var(--color-ink);
    pointer-events: none;
  }

  .intro__photo-corner--tl { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
  .intro__photo-corner--tr { top: 8px; right: 8px; border-left: 0; border-bottom: 0; }
  .intro__photo-corner--bl { bottom: 8px; left: 8px; border-right: 0; border-top: 0; }
  .intro__photo-corner--br { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }

  /* ============ Right column ============ */

  .intro__content {
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }

  /* The letter itself: three paragraphs, one face, one size. Hierarchy
     comes from the bold lead-in phrase alone, so the block reads as a
     single unified voice. */
  .intro__letter {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .intro__para {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.62;
    color: var(--color-ink);
    max-width: 60ch;
    text-wrap: pretty;
  }

  .intro__lead {
    font-weight: 600;
    color: var(--color-ink);
  }

  /* ============ Contact strip ============ */

  .intro__contact-row {
    margin-top: 4px;
    padding-top: 22px;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 720px) {
    .intro__contact-row {
      padding-top: 18px;
    }
  }

  .intro__email-row {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .intro__email-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .intro__email-addr {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 83, 71, 0.35);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: color var(--motion-warm), border-color var(--motion-warm);
  }

  .intro__email-addr:hover,
  .intro__email-addr:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  .intro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-start;
    align-items: center;
  }

  /* Tighter pill chrome so all four profile/CV pills fit one row inside
     the right column. Tap target stays at 40px. */
  .intro__pills :global(.pill) {
    padding: 10px 13px;
    min-height: 40px;
    font-size: 10.5px;
    letter-spacing: 0.09em;
  }
</style>
