---
import siteConfig from "~/content/site.json";
import Icon from "./Icon.astro";

const themes = siteConfig.researchThemes;
const intro = siteConfig.researchThemesIntro;
---

<section class="themes" aria-label="Research themes">
  <header class="themes__header">
    <span class="themes__rule" aria-hidden="true"></span>
    <h2 class="themes__heading">A research compass</h2>
    <span class="themes__rule" aria-hidden="true"></span>
  </header>

  <p class="themes__intro">{intro}</p>

  <ul class="themes__grid">
    {themes.map((t, i) => (
      <li class={`themes__card ${t.id === "fairness-access" ? "themes__card--north" : ""}`}>
        <div class="themes__card-glyph" aria-hidden="true">
          <Icon name={t.icon} size={32} strokeWidth={1.3} />
        </div>
        <h3 class="themes__card-title">{t.title}</h3>
        <p class="themes__card-blurb">{t.blurb}</p>
      </li>
    ))}
  </ul>

  <!-- Decorative bottom band: "two threads" annotation -->
  <div class="themes__threads" aria-hidden="true">
    <svg viewBox="0 0 800 60" class="themes__threads-svg" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 30 Q120 12 220 30 Q320 48 420 30 Q520 12 620 30 Q720 48 780 30" stroke-width="1" />
      <path d="M20 36 Q120 18 220 36 Q320 54 420 36 Q520 18 620 36 Q720 54 780 36" stroke-width="0.6" stroke-dasharray="2 4" opacity="0.6" />
      <circle cx="160" cy="22" r="2" fill="currentColor" stroke="none" />
      <circle cx="420" cy="32" r="2.4" fill="currentColor" stroke="none" />
      <circle cx="640" cy="40" r="2" fill="currentColor" stroke="none" />
    </svg>
    <p class="themes__threads-label">
      <span>beyond text</span>
      <span class="themes__threads-x">×</span>
      <span>access in practice</span>
    </p>
  </div>
</section>

<style>
  .themes {
    /* Wider than the body content so the 4-card row breathes. The intro
       paragraph is still constrained to 68ch below. */
    max-width: var(--content-with-rail);
    margin: 80px auto 32px;
    padding: 24px;
  }

  .themes__header {
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }

  .themes__rule {
    flex: 1 1 auto;
    max-width: 180px;
    height: 1px;
    background: var(--color-hairline);
  }

  .themes__heading {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  .themes__intro {
    margin: 0 auto 40px;
    max-width: 68ch;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.6;
    color: var(--color-ink-soft);
    text-align: center;
    text-wrap: balance;
  }

  .themes__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    /* Eight themes, read as the eight directions of a compass. 4×2 at
       desktop, 2×4 at tablet, single column on phone. */
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-hairline);
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
  }

  @media (max-width: 1100px) {
    .themes__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .themes__grid {
      grid-template-columns: 1fr;
    }
    /* Tighten the stacked cards so the section reads as a compass, not a
       staircase. Codex iter-15 critique: cards were eating too much
       vertical scroll before the actual papers. */
    .themes__intro {
      margin: 0 auto 28px;
    }
    .themes__card {
      padding: 20px 20px 18px;
      gap: 10px;
    }
    .themes__card-glyph {
      height: 28px;
    }
    .themes__card-title {
      font-size: 20px;
    }
    .themes__card-blurb {
      font-size: 14px;
      line-height: 1.5;
    }
  }

  .themes__card {
    background: var(--color-paper-shade);
    /* Slightly tighter horizontal padding at desktop (4-col) so the
       longer titles don't break onto an awkward third line. The 2-col
       breakpoint below opens it back up. */
    padding: 24px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 160ms ease-out;
    position: relative;
  }

  @media (max-width: 1100px) {
    .themes__card {
      padding: 26px 24px 24px;
      gap: 14px;
    }
  }

  .themes__card:hover {
    background: var(--color-paper);
  }

  .themes__card--north {
    background: var(--color-featured);
  }

  .themes__card--north:hover {
    background: var(--color-featured);
  }

  .themes__card-glyph {
    color: var(--color-ink);
    height: 36px;
    display: flex;
    align-items: center;
    transition: color 160ms ease-out;
  }

  /* Glyph picks up the accent on hover so the card signals interactivity
     without resorting to a heavy border or shadow change. */
  .themes__card:hover .themes__card-glyph {
    color: var(--color-accent);
  }

  .themes__card--north .themes__card-glyph {
    color: var(--color-accent);
  }

  .themes__card-title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    /* Fluid: tightens at 4-col desktop where cards are narrower, opens
       up to 22px in 2-col / 1-col modes. */
    font-size: clamp(19px, 1.6vw, 22px);
    line-height: 1.18;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .themes__card-blurb {
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .themes__card--north .themes__card-blurb {
    color: var(--color-ink);
  }

  .themes__threads {
    margin-top: 36px;
    text-align: center;
    color: var(--color-ink-soft);
  }

  .themes__threads-svg {
    width: 100%;
    max-width: 800px;
    height: auto;
    display: block;
    margin: 0 auto;
    opacity: 0.45;
  }

  .themes__threads-label {
    margin: 10px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-ink-soft);
    display: inline-flex;
    gap: 14px;
    align-items: baseline;
  }

  .themes__threads-x {
    color: var(--color-accent);
    font-size: 18px;
  }
</style>
