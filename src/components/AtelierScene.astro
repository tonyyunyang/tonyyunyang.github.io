    animation: atelierTennisBall 4.2s ease-in-out infinite;
  }

  /* Houseboat bobs gently on the canal */
  @keyframes atelierHouseboatBob {
    0%, 100% { transform: translateY(0)    rotate(0deg);   }
    25%      { transform: translateY(-2px) rotate(-0.7deg); }
