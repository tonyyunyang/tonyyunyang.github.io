<style>
  .atelier {
    position: fixed;
    inset: 0;
    background: var(--color-paper);
    overflow: hidden;
    z-index: 40;
    display: flex;
    flex-direction: column;
  }

  .atelier__chrome {
    flex: 0 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 18px 28px;
    gap: 24px;
    border-bottom: 1px solid var(--color-hairline);
    background: rgba(245, 239, 226, 0.92);
    backdrop-filter: blur(2px);
    z-index: 5;
  }

  .atelier__breadcrumb {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .atelier__breadcrumb-mono {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .atelier__breadcrumb-mono--soft {
    opacity: 0.7;
  }

  .atelier__breadcrumb-display {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--color-ink);
    line-height: 1;
  }

  .atelier__hint {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    text-align: center;
  }

  .atelier__hint kbd {
    font-family: inherit;
    font-size: inherit;
    border: 1px solid var(--color-hairline);
    padding: 1px 5px;
    border-radius: 3px;
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .atelier__close {
    justify-self: end;
    background: transparent;
    border: 1px solid var(--color-hairline);
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 10px;
    border-radius: 4px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 180ms ease-out, border-color 180ms ease-out;
  }

  .atelier__close:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .atelier__close-arrow {
    font-size: 14px;
  }

  .atelier__stage {
    position: relative;
    flex: 1 1 auto;
    width: 100%;
    overflow: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    box-sizing: border-box;
  }

  .atelier__canvas {
    position: relative;
    width: 100%;
    max-width: 1500px;
    aspect-ratio: 16 / 10;
    flex: 0 0 auto;
  }

  .atelier__art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .atelier__hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    border: 0;
    background: transparent;
    padding: 14px;
    cursor: pointer;
    color: var(--color-ink);
    z-index: 3;
  }

  .atelier__hotspot:disabled {
    cursor: default;
  }

  .atelier__hotspot-dot {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    border: 1.5px solid var(--color-ink-soft);
    background: rgba(245, 239, 226, 0.4);
    box-shadow: 0 0 0 6px rgba(245, 239, 226, 0.25);
    transition:
      background 180ms ease-out,
      border-color 180ms ease-out,
      transform 180ms ease-out,
      box-shadow 180ms ease-out;
  }

  .atelier__hotspot:hover .atelier__hotspot-dot,
  .atelier__hotspot:focus-visible .atelier__hotspot-dot,
  .atelier[data-show-captions] .atelier__hotspot-dot {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.15);
    box-shadow: 0 0 0 8px rgba(14, 83, 71, 0.18);
  }

  .atelier__hotspot-label {
    position: absolute;
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    background: var(--color-paper);
    padding: 2px 6px;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
    opacity: 0;
    transition: opacity 180ms;
    pointer-events: none;
  }

  .atelier[data-show-captions] .atelier__hotspot-label,
  .atelier__hotspot:hover .atelier__hotspot-label,
  .atelier__hotspot:focus-visible .atelier__hotspot-label {
    opacity: 1;
  }

  .atelier__hotspot:disabled .atelier__hotspot-dot {
    border-style: dashed;
    background: transparent;
  }

  .atelier__panel {
    position: fixed;
    right: 28px;
    bottom: 28px;
    width: min(380px, calc(100% - 56px));
    background: var(--color-paper-shade);
    border: 1px solid var(--color-hairline);
    border-radius: 16px;
    padding: 22px 24px 20px;
    z-index: 6;
    box-shadow:
      0 1px 0 rgba(15, 20, 23, 0.04),
      0 18px 40px -18px rgba(15, 20, 23, 0.18);
  }

  .atelier__panel-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }

  .atelier__panel-note {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    line-height: 1.45;
    color: var(--color-ink);
  }

  .atelier__panel-close {
    margin-top: 14px;
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .atelier__panel-close:hover {
    color: var(--color-accent);
  }

  .atelier__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  @media (max-width: 720px) {
    .atelier__chrome {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      padding: 14px 18px;
      gap: 8px 16px;
    }
    .atelier__breadcrumb {
      grid-column: 1 / 2;
    }
    .atelier__close {
      grid-column: 2 / 3;
      grid-row: 1 / 2;
    }
    .atelier__hint {
      grid-column: 1 / 3;
      grid-row: 2 / 3;
      text-align: left;
    }
    .atelier__breadcrumb-display {
      font-size: 18px;
    }
    .atelier__stage {
      align-items: flex-start;
      padding: 16px 12px;
    }
    .atelier__panel {
      right: 12px;
      bottom: 12px;
    }
    .atelier__hotspot {
      padding: 10px;
