---
import scene from "~/content/atelier.json";

const objects = scene.scene.objects;
const allNotes = objects.filter(
  (o): o is typeof o & { note: string } => "note" in o && Boolean(o.note)
);
---

<div class="atelier" data-atelier>
  <header class="atelier__chrome">
    <p class="atelier__breadcrumb">
      <span class="atelier__breadcrumb-mono">No. 03</span>
      <span class="atelier__breadcrumb-display">{scene.scene.title}</span>
      <span class="atelier__breadcrumb-mono atelier__breadcrumb-mono--soft"
        >{scene.scene.subtitle}</span
      >
    </p>
    <p class="atelier__hint" data-atelier-hint>
      click an object · <kbd>T</kbd> all notes · <kbd>Esc</kbd> close
    </p>
    <button
      class="atelier__close"
      type="button"
      data-atelier-close
      aria-label="Close studio"
    >
      <span class="atelier__close-key">Esc</span>
      <span class="atelier__close-arrow" aria-hidden="true">↘</span>
    </button>
  </header>

  <div class="atelier__stage" data-atelier-stage>
    <div class="atelier__canvas">
    <svg
      class="atelier__art"
      viewBox="0 0 1600 1000"
      role="img"
      aria-label="An ink illustration of Tony's studio, viewed as an architectural cross-section. Bookshelf at left, reading chair and cat in front of it, a desk at center facing a tall window onto an Amsterdam canal at evening, and a small kitchen alcove to the right with a pot on a stove."
      preserveAspectRatio="xMidYMid meet"
    >
      <defs>
        <pattern
          id="planks"
          patternUnits="userSpaceOnUse"
          width="160"
          height="40"
          patternTransform="translate(0,0)"
        >
          <path
            d="M0 39.5 H160"
            stroke="#0f1417"
            stroke-width="0.6"
            opacity="0.55"
          ></path>
          <path d="M0 0 V40" stroke="#0f1417" stroke-width="0.5" opacity="0.4"
          ></path>
          <path d="M80 0 V40" stroke="#0f1417" stroke-width="0.5" opacity="0.3"
          ></path>
        </pattern>
        <pattern
          id="hatch"
          patternUnits="userSpaceOnUse"
          width="6"
          height="6"
          patternTransform="rotate(35)"
        >
          <line x1="0" y1="0" x2="0" y2="6" stroke="#0f1417" stroke-width="0.7"
          ></line>
        </pattern>
        <pattern
          id="hatchSoft"
          patternUnits="userSpaceOnUse"
          width="8"
          height="8"
          patternTransform="rotate(-30)"
        >
          <line
            x1="0"
            y1="0"
            x2="0"
            y2="8"
            stroke="#0f1417"
            stroke-width="0.5"
          ></line>
        </pattern>
        <radialGradient id="lampGlow" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.95"></stop>
          <stop offset="0.45" stop-color="#FAF1D8" stop-opacity="0.6"></stop>
          <stop offset="1" stop-color="#FAF1D8" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="lampGlowDesk" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.85"></stop>
          <stop offset="0.5" stop-color="#FAF1D8" stop-opacity="0.45"></stop>
          <stop offset="1" stop-color="#FAF1D8" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="moonGlow" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.7"></stop>
          <stop offset="0.5" stop-color="#FAF1D8" stop-opacity="0.3"></stop>
          <stop offset="1" stop-color="#FAF1D8" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="candleGlow" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.85"></stop>
          <stop offset="0.4" stop-color="#FAF1D8" stop-opacity="0.4"></stop>
          <stop offset="1" stop-color="#FAF1D8" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="windowGlow" cx="0.5" cy="0.7" r="0.7">
          <stop offset="0" stop-color="#0E5347" stop-opacity="0.10"></stop>
          <stop offset="1" stop-color="#0E5347" stop-opacity="0"></stop>
        </radialGradient>
        <filter id="paperNoise">
          <feTurbulence type="fractalNoise" baseFrequency="1.3" numOctaves="2" seed="3"></feTurbulence>
          <feColorMatrix values="0 0 0 0 0.06 0 0 0 0 0.08 0 0 0 0 0.09 0 0 0 0.08 0"></feColorMatrix>
          <feComposite in2="SourceGraphic" operator="in"></feComposite>
        </filter>
      </defs>

      <!-- ROOM FRAME (outer cross-section) -->
      <g class="ink" stroke="#0f1417" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- Outer wall opening -->
        <path d="M80 80 H1520 V920 H80 Z" stroke-width="2.4"></path>
        <!-- Inner wall depth -->
        <path d="M140 200 H1460 V900 H140 Z" stroke-width="1.4" opacity="0.85"></path>
        <!-- Wall thickness hatch (top + sides) -->
        <path d="M80 80 L140 200" stroke-width="0.9" opacity="0.55"></path>
        <path d="M1520 80 L1460 200" stroke-width="0.9" opacity="0.55"></path>
        <path d="M80 920 L140 900" stroke-width="0.9" opacity="0.55"></path>
        <path d="M1520 920 L1460 900" stroke-width="0.9" opacity="0.55"></path>
        <!-- Ceiling beam suggestion -->
        <path d="M180 240 H1420" stroke-width="0.7" stroke-dasharray="5 9" opacity="0.55"></path>
      </g>

      <!-- WARM WINDOW WASH (light spilling into room) -->
      <ellipse cx="820" cy="600" rx="500" ry="260" fill="url(#windowGlow)"></ellipse>
      <!-- WARM LAMP POOL on desk (cast light from above, broader) -->
      <ellipse cx="820" cy="700" rx="320" ry="60" fill="url(#lampGlowDesk)" opacity="0.85"></ellipse>
      <!-- Inner intense pool exactly on the laptop -->
      <ellipse cx="820" cy="688" rx="140" ry="28" fill="url(#lampGlowDesk)" opacity="0.95"></ellipse>

      <!-- FLOOR (planks fill, with hatch line at edge) -->
      <rect x="140" y="858" width="1320" height="42" fill="url(#planks)" opacity="0.7"></rect>
      <path d="M140 858 H1460" stroke="#0f1417" stroke-width="1.2"></path>
      <path d="M140 870 H1460" stroke="#0f1417" stroke-width="0.5" opacity="0.4"></path>

      <!-- BASEBOARD shadow -->
      <rect x="140" y="846" width="1320" height="14" fill="url(#hatchSoft)" opacity="0.45"></rect>

      <!-- =================================================== -->
      <!-- BOOKSHELF (left wall)                                -->
      <!-- =================================================== -->
      <g class="ink" stroke="#0f1417" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- Frame -->
        <rect x="170" y="240" width="220" height="620" stroke-width="1.6"></rect>
        <!-- Inside shadow -->
        <rect x="174" y="244" width="212" height="612" fill="url(#hatchSoft)" stroke="none" opacity="0.18"></rect>
        <!-- Shelves -->
        <path d="M170 340 H390" stroke-width="1.2"></path>
        <path d="M170 440 H390" stroke-width="1.2"></path>
        <path d="M170 540 H390" stroke-width="1.2"></path>
        <path d="M170 640 H390" stroke-width="1.2"></path>
        <path d="M170 740 H390" stroke-width="1.2"></path>
        <!-- Top ornament -->
        <path d="M165 240 H395" stroke-width="2.2"></path>
        <path d="M180 232 Q195 222 220 232 Q245 242 280 232 Q315 222 350 232 Q375 240 380 232" stroke-width="0.9" opacity="0.6"></path>
      </g>

      <!-- Books on shelves (each a vertical rectangle, varied heights/widths/fills) -->
      <g class="books-row" stroke="#0f1417" stroke-width="1" stroke-linejoin="miter">
        <!-- Shelf 1 (top) -->
        <rect x="184" y="282" width="14" height="58" fill="#EDE6D5"></rect>
        <rect x="200" y="276" width="20" height="64" fill="#0f1417" opacity="0.9"></rect>
        <rect x="222" y="290" width="12" height="50" fill="#EDE6D5"></rect>
        <rect x="236" y="284" width="22" height="56" fill="#0f1417" opacity="0.85"></rect>
        <rect x="260" y="294" width="16" height="46" fill="#EDE6D5"></rect>
        <rect x="278" y="278" width="18" height="62" fill="#0E5347" opacity="0.85"></rect>
        <rect x="298" y="288" width="14" height="52" fill="#EDE6D5"></rect>
        <rect x="314" y="282" width="20" height="58" fill="#0f1417" opacity="0.85"></rect>
        <!-- Tilted book -->
        <path d="M340 340 L340 296 L356 302 L356 340 Z" fill="#EDE6D5" stroke="#0f1417"></path>
        <!-- Spine titles (just hairlines) -->
        <path d="M188 300 H194 M204 295 H214 M226 305 H230 M240 295 H252 M264 305 H272 M282 295 H290 M302 302 H308 M318 295 H328" stroke="#0f1417" stroke-width="0.6" opacity="0.5"></path>

        <!-- Shelf 2 -->
        <rect x="184" y="380" width="22" height="60" fill="#EDE6D5"></rect>
        <rect x="208" y="386" width="14" height="54" fill="#0f1417" opacity="0.85"></rect>
        <rect x="224" y="378" width="18" height="62" fill="#EDE6D5"></rect>
        <rect x="244" y="382" width="22" height="58" fill="#0E5347" opacity="0.8"></rect>
        <!-- Stack lying down -->
        <rect x="270" y="416" width="60" height="10" fill="#EDE6D5" stroke="#0f1417"></rect>
        <rect x="272" y="406" width="58" height="10" fill="#0f1417" opacity="0.8"></rect>
        <rect x="278" y="396" width="50" height="10" fill="#EDE6D5"></rect>
        <rect x="334" y="384" width="14" height="56" fill="#0f1417" opacity="0.85"></rect>
        <rect x="350" y="388" width="18" height="52" fill="#EDE6D5"></rect>
        <rect x="370" y="382" width="14" height="58" fill="#0f1417" opacity="0.8"></rect>

        <!-- Shelf 3 -->
        <rect x="184" y="478" width="18" height="62" fill="#0f1417" opacity="0.9"></rect>
        <rect x="204" y="490" width="20" height="50" fill="#EDE6D5"></rect>
        <rect x="226" y="482" width="14" height="58" fill="#0E5347" opacity="0.85"></rect>
        <rect x="242" y="486" width="22" height="54" fill="#0f1417" opacity="0.8"></rect>
        <rect x="266" y="492" width="16" height="48" fill="#EDE6D5"></rect>
        <rect x="284" y="478" width="18" height="62" fill="#0f1417" opacity="0.85"></rect>
        <rect x="304" y="488" width="14" height="52" fill="#EDE6D5"></rect>
        <rect x="320" y="480" width="22" height="60" fill="#0f1417" opacity="0.9"></rect>
        <rect x="344" y="490" width="16" height="50" fill="#EDE6D5"></rect>
        <rect x="362" y="484" width="22" height="56" fill="#0f1417" opacity="0.85"></rect>

        <!-- Shelf 4 -->
        <rect x="184" y="582" width="14" height="58" fill="#EDE6D5"></rect>
        <rect x="200" y="576" width="20" height="64" fill="#0f1417" opacity="0.9"></rect>
        <rect x="224" y="588" width="14" height="52" fill="#EDE6D5"></rect>
        <rect x="240" y="582" width="20" height="58" fill="#0E5347" opacity="0.8"></rect>
        <!-- Globe / sphere for variety -->
        <circle cx="278" cy="612" r="22" fill="#EDE6D5" stroke="#0f1417" stroke-width="1"></circle>
        <path d="M256 612 H300 M278 590 V634 M260 600 Q278 608 296 600 M260 624 Q278 616 296 624" stroke="#0f1417" stroke-width="0.5" fill="none" opacity="0.55"></path>
        <path d="M278 588 V638 M270 590 L286 634" stroke="#0f1417" stroke-width="0.4" opacity="0.4" fill="none"></path>
        <rect x="306" y="582" width="18" height="58" fill="#0f1417" opacity="0.85"></rect>
        <rect x="326" y="586" width="22" height="54" fill="#EDE6D5"></rect>
        <rect x="350" y="580" width="14" height="60" fill="#0f1417" opacity="0.9"></rect>
        <rect x="366" y="588" width="18" height="52" fill="#EDE6D5"></rect>

        <!-- Shelf 5 (bottom — large books, papers) -->
        <rect x="184" y="676" width="60" height="64" fill="#EDE6D5"></rect>
        <rect x="186" y="678" width="56" height="60" fill="none" stroke="#0f1417" stroke-width="0.5" opacity="0.5"></rect>
        <path d="M194 690 H230 M194 700 H222 M194 710 H230 M194 720 H218 M194 730 H226" stroke="#0f1417" stroke-width="0.5" opacity="0.55"></path>
        <rect x="248" y="678" width="20" height="62" fill="#0f1417" opacity="0.85"></rect>
        <rect x="272" y="688" width="14" height="52" fill="#EDE6D5"></rect>
        <rect x="288" y="678" width="22" height="62" fill="#0E5347" opacity="0.8"></rect>
        <!-- Camera/object for character -->
        <rect x="316" y="710" width="60" height="30" fill="#EDE6D5" stroke="#0f1417" stroke-width="1"></rect>
        <circle cx="346" cy="725" r="8" fill="none" stroke="#0f1417" stroke-width="1"></circle>
        <circle cx="346" cy="725" r="4" fill="#0f1417"></circle>
        <rect x="328" y="704" width="14" height="8" fill="none" stroke="#0f1417" stroke-width="0.7"></rect>

        <!-- Bottom-most shelf (stacks of paper drafts) -->
        <rect x="184" y="772" width="100" height="14" fill="#EDE6D5" stroke="#0f1417" stroke-width="0.7"></rect>
        <rect x="186" y="758" width="96" height="14" fill="#FAF1D8" stroke="#0f1417" stroke-width="0.7"></rect>
        <rect x="190" y="744" width="90" height="14" fill="#EDE6D5" stroke="#0f1417" stroke-width="0.7"></rect>
        <path d="M194 752 H262 M196 766 H258 M196 780 H266" stroke="#0f1417" stroke-width="0.4" opacity="0.5" fill="none"></path>
        <rect x="296" y="746" width="18" height="60" fill="#0f1417" opacity="0.85"></rect>
        <rect x="318" y="752" width="22" height="54" fill="#EDE6D5"></rect>
        <rect x="344" y="744" width="14" height="62" fill="#0E5347" opacity="0.85"></rect>
        <rect x="362" y="754" width="20" height="52" fill="#EDE6D5"></rect>
      </g>

      <!-- Hook + medal hanging on the side of bookshelf
           (the ribbon + disc swing gently as a pendulum from the hook end) -->
      <g stroke="#0f1417" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- Hook (fixed) -->
        <path d="M398 320 L408 320 L408 348" stroke-width="1.4"></path>
        <g class="atelier__medal-swing">
          <!-- Ribbon -->
          <path d="M404 348 L398 396 M412 348 L418 396" stroke-width="1" fill="none"></path>
          <path d="M396 396 L420 396 L416 410 L400 410 Z" fill="#0E5347" stroke-width="1"></path>
          <!-- Medal disc -->
          <circle cx="408" cy="438" r="22" fill="#FAF1D8" stroke-width="1.4"></circle>
          <circle cx="408" cy="438" r="16" fill="none" stroke-width="0.7" opacity="0.7"></circle>
          <text x="408" y="444" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#0f1417" stroke="none" letter-spacing="0.04em">21.1</text>
        </g>
      </g>

      <!-- =================================================== -->
      <!-- READING CHAIR + CAT + RUG                            -->
      <!-- =================================================== -->
      <g class="ink" stroke="#0f1417" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- Rug -->
        <ellipse cx="370" cy="884" rx="200" ry="14" fill="#EDE6D5" stroke-width="1"></ellipse>
        <ellipse cx="370" cy="884" rx="180" ry="10" fill="none" stroke-width="0.6" opacity="0.7"></ellipse>
        <!-- Rug pattern hash -->
        <path d="M220 880 H520 M230 888 H510" stroke-width="0.5" stroke-dasharray="2 6" opacity="0.65"></path>

        <!-- Chair shadow -->
        <ellipse cx="370" cy="884" rx="120" ry="8" fill="url(#hatchSoft)" stroke="none" opacity="0.4"></ellipse>

        <!-- Chair (high-backed armchair, 3/4 view from side) -->
        <!-- Back -->
        <path d="M286 740 Q280 690 296 690 Q310 690 312 700 L312 836 Q312 850 296 854 L286 854 Q284 824 286 800 Z" fill="#EDE6D5" stroke-width="1.6"></path>
        <!-- Seat cushion -->
        <path d="M296 836 Q310 830 380 832 Q442 832 446 838 L450 854 Q420 858 380 858 Q330 858 304 856 Z" fill="#FAF1D8" stroke-width="1.4"></path>
        <!-- Front of seat (front legs visible) -->
        <path d="M324 858 L320 882 M438 858 L442 882" stroke-width="1.4"></path>
        <!-- Right armrest -->
        <path d="M442 836 Q458 832 458 800 L458 760 Q450 750 446 762 L446 836" fill="#EDE6D5" stroke-width="1.4"></path>
        <!-- Pillow on chair -->
        <path d="M312 770 Q330 750 358 752 Q380 754 384 776 Q386 798 360 802 Q330 804 314 796 Z" fill="#0E5347" stroke-width="1" opacity="0.85"></path>
        <path d="M324 762 Q344 760 360 762 M324 790 Q344 794 360 790" stroke="#FAF1D8" stroke-width="0.6" fill="none" opacity="0.85"></path>
      </g>

      <!-- Cat (狸花猫 · Chinese mackerel tabby, sitting alert on chair seat).
           Iter 12 anatomical-realism rebuild: correct head:body ratio, layered
           fur tones (paper-shade body over hairline shadow), bold mackerel
           bands, tail wrapped to the front, dark slit-pupil eyes (NOT green).
           Bands hand-placed to follow real tabby pattern: vertical streaks
           down the flanks, ringed tail, spiked M-mark on forehead. -->
      <g class="atelier__cat" stroke="#0f1417" stroke-linecap="round" stroke-linejoin="round" fill="none">

        <!-- ============ TAIL (curls around front of chair, ringed) ============ -->
        <g class="atelier__cat-tail">
          <!-- Tail base sweeping out from rump, around to the front -->
          <path
            d="M412 858 Q442 854 454 870 Q462 884 454 894 Q444 904 418 902 Q396 900 384 892"
            fill="#EDE6D5"
            stroke="#0F1417"
            stroke-width="2.1"
          ></path>
          <!-- Hairline shadow underbelly of tail -->
          <path
            d="M398 898 Q418 902 442 900 Q452 898 456 892"
            fill="none"
            stroke="#D9D2C2"
            stroke-width="1.4"
            opacity="0.85"
          ></path>
          <!-- Tail rings (4 bold dark bands) -->
          <path d="M410 858 Q418 864 422 870" stroke="#0F1417" stroke-width="2.4"></path>
          <path d="M428 860 Q438 866 442 874" stroke="#0F1417" stroke-width="2.4"></path>
          <path d="M450 876 Q456 884 452 892" stroke="#0F1417" stroke-width="2.4"></path>
          <path d="M432 898 Q442 898 448 894" stroke="#0F1417" stroke-width="2.4"></path>
          <!-- Tail tip dark cap -->
          <path d="M386 894 Q392 902 402 900 Q396 894 386 894 Z" fill="#0F1417" stroke="none"></path>
        </g>

        <!-- ============ BODY (seated, with shoulder/haunch separation) ============ -->
        <!-- Hairline-shaded undertone (creates fur depth — appears below the body fill on rump and chest sides) -->
        <path
          d="M320 858 Q316 838 322 818 Q330 800 348 794 L398 794 Q418 800 426 820 Q430 842 422 862 Q412 880 384 884 Q346 886 326 874 Q320 866 320 858 Z"
          fill="#D9D2C2"
          stroke="none"
        ></path>
        <!-- Main body silhouette (tapered haunch + chest, paper-shade fur) -->
        <path
          d="M324 856 Q318 836 326 814 Q336 794 358 788 Q386 784 404 794 Q422 804 426 826 Q430 850 416 866 Q400 880 374 882 Q346 884 328 870 Q324 864 324 856 Z"
          fill="#EDE6D5"
          stroke="#0F1417"
          stroke-width="2.1"
        ></path>
        <!-- Front-leg break line (subtle, separates chest from foreleg) -->
        <path d="M362 826 Q360 850 368 874" stroke="#0F1417" stroke-width="0.8" opacity="0.5"></path>

        <!-- ============ CREAM CHEST + PAWS ============ -->
        <path
          d="M348 818 Q364 808 384 814 Q396 832 392 856 Q382 874 364 876 Q346 872 342 856 Q340 832 348 818 Z"
          fill="#FAF1D8"
          stroke="#0F1417"
          stroke-width="1.6"
        ></path>
        <!-- Front left paw (tucked) -->
        <path
          d="M344 870 Q350 862 362 866 Q368 876 360 882 Q348 884 342 878 Q340 872 344 870 Z"
          fill="#FAF1D8"
          stroke="#0F1417"
          stroke-width="1.6"
        ></path>
        <!-- Front right paw (tucked) -->
        <path
          d="M368 868 Q378 860 388 866 Q392 876 384 882 Q374 884 368 878 Q366 872 368 868 Z"
          fill="#FAF1D8"
          stroke="#0F1417"
          stroke-width="1.6"
        ></path>
        <!-- Toe separations on paws -->
        <path d="M350 880 L350 884 M356 882 L356 886 M376 880 L376 884 M382 882 L382 886" stroke="#0F1417" stroke-width="0.9" opacity="0.7"></path>

        <!-- ============ MACKEREL BANDS (shoulder + flank, vertical streaks) ============ -->
        <!-- Shoulder band (diagonal across upper body) -->
        <path d="M326 808 Q336 802 348 806 Q346 814 344 824 Q334 822 326 808 Z" fill="#0F1417" stroke="none"></path>
        <!-- Mid-flank band -->
        <path d="M326 826 Q340 820 352 822 Q350 836 348 850 Q336 846 326 836 Z" fill="#0F1417" stroke="none"></path>
        <!-- Lower flank band -->
        <path d="M334 854 Q346 848 360 854 Q358 866 356 876 Q344 874 334 866 Z" fill="#0F1417" stroke="none"></path>
        <!-- Right side shoulder band -->
        <path d="M398 798 Q410 802 418 814 Q412 822 402 824 Q400 812 398 798 Z" fill="#0F1417" stroke="none"></path>
        <!-- Right side mid band -->
        <path d="M402 826 Q416 830 424 842 Q416 850 404 850 Q406 838 402 826 Z" fill="#0F1417" stroke="none"></path>
        <!-- Right side rump band -->
        <path d="M398 854 Q412 856 420 868 Q412 874 402 872 Q402 864 398 854 Z" fill="#0F1417" stroke="none"></path>
        <!-- Thin secondary stripes (between major bands, hand-drawn feel) -->
        <path d="M340 818 Q344 822 342 832" stroke="#0F1417" stroke-width="1.2" opacity="0.65"></path>
        <path d="M408 822 Q412 828 410 836" stroke="#0F1417" stroke-width="1.2" opacity="0.65"></path>
        <path d="M348 842 Q352 848 350 856" stroke="#0F1417" stroke-width="1.2" opacity="0.65"></path>

        <!-- ============ HEAD (rounded triangle with proper tabby proportions) ============ -->
        <!-- Head shadow (hairline tone behind ears) -->
        <path
          d="M334 802 Q330 778 348 762 Q368 750 388 750 Q406 752 416 768 Q424 786 422 802 Q418 824 402 836 Q384 846 362 842 Q344 840 336 824 Q332 814 334 802 Z"
          fill="#D9D2C2"
          stroke="none"
        ></path>
        <!-- Head silhouette -->
        <path
          d="M336 800 Q334 776 350 762 Q370 750 388 750 Q406 752 414 766 Q422 784 420 800 Q418 822 402 832 Q384 842 362 840 Q346 836 338 822 Q334 812 336 800 Z"
          fill="#EDE6D5"
          stroke="#0F1417"
          stroke-width="2.1"
        ></path>

