  .atelier__star--b { animation-duration: 3.2s; animation-delay: 0.4s; }
  .atelier__star--c { animation-duration: 2.8s; animation-delay: 0.8s; }
  .atelier__star--d { animation-duration: 3.6s; animation-delay: 1.2s; }
  .atelier__star--e { animation-duration: 2.6s; animation-delay: 1.6s; }
  .atelier__star--f { animation-duration: 3s;   animation-delay: 0.2s; }

  /* Clock hands rotate (theatrical pace, not real-time) */
  @keyframes atelierClockSpin {
    0%   { transform: rotate(0deg);   }
    100% { transform: rotate(360deg); }
  }
  .atelier__clock-hour {
    transform-origin: 1130px 306px;
    transform-box: view-box;
    animation: atelierClockSpin 60s linear infinite;
  }
  .atelier__clock-minute {
    transform-origin: 1130px 306px;
