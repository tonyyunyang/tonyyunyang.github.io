    75%      { transform: translateY(-1px) rotate(-0.3deg); }
  }
  .atelier__houseboat {
    transform-origin: center;
    transform-box: fill-box;
    animation: atelierHouseboatBob 3.6s ease-in-out infinite;
  }

  /* Water ripples shimmer / drift sideways at different rates */
  @keyframes atelierWaterRipple {
    0%, 100% { transform: translateX(0);    opacity: 0.7; }
    50%      { transform: translateX(10px); opacity: 0.4; }
  }
  .atelier__water-ripple {
    animation: atelierWaterRipple 5s ease-in-out infinite;
  }
  .atelier__water-ripple--b { animation-duration: 6s;   animation-delay: 0.5s; }
  .atelier__water-ripple--c { animation-duration: 7s;   animation-delay: 1s;   }
  .atelier__water-ripple--d { animation-duration: 5.5s; animation-delay: 1.5s; }

  /* Pendant lamp sways slightly from the ceiling cap */
  @keyframes atelierPendantSway {
    0%, 100% { transform: rotate(-1.6deg); }
    50%      { transform: rotate(1.6deg);  }
  }
  .atelier__pendant-sway {
    transform-origin: 820px 204px;
    transform-box: view-box;
    animation: atelierPendantSway 6.8s ease-in-out infinite;
  }

  /* Curtain waves like a draft is coming through the window */
  @keyframes atelierCurtainWave {
    0%, 100% { transform: translateX(0)    skewX(0deg);   }
    50%      { transform: translateX(-1.5px) skewX(-1deg); }
  }
  .atelier__curtain {
    transform-origin: top;
    transform-box: fill-box;
    animation: atelierCurtainWave 5.2s ease-in-out infinite;
  }

  /* Cat tail twitches occasionally (mostly still, a flick every cycle) */
  @keyframes atelierCatTailTwitch {
    0%, 78%, 100% { transform: rotate(0deg); }
    82%, 92%      { transform: rotate(-5deg); }
    87%           { transform: rotate(5deg); }
  }
  .atelier__cat-tail {
    transform-origin: 426px 812px;
    transform-box: view-box;
    animation: atelierCatTailTwitch 7s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .atelier__hotspot-dot,
    .atelier__hotspot-label {
      transition: none;
    }
    .atelier__lamp-glow,
    .atelier__lamp-bulb,
    .atelier__moon-halo,
    .atelier__candle-flame,
    .atelier__candle-halo,
    .atelier__coffee-steam,
    .atelier__wok-flame,
    .atelier__wok-steam,
    .atelier__tulips,
    .atelier__cat-zzz,
    .atelier__star,
    .atelier__clock-hour,
    .atelier__clock-minute,
    .atelier__medal-swing,
    .atelier__tennis-ball,
    .atelier__houseboat,
    .atelier__water-ripple,
    .atelier__pendant-sway,
    .atelier__curtain,
    .atelier__cat-tail {
      animation: none;
    }
  }
</style>
