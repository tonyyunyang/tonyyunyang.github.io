     visitors learn what is clickable, then fade to the default
     hover-only state. Long fade so it feels intentional. */
  .atelier[data-initial-reveal] .atelier__hotspot-dot {
    box-shadow: 0 0 0 12px rgba(14, 83, 71, 0.22);
  }

  .atelier__hotspot-label {
    transition: opacity 600ms ease-out;
  }

  /* ============ IDLE MOTION ============
     Subtle, atmospheric: the room feels lived-in but never distracts. */

  @keyframes atelierLampPulse {
    0%, 100% { opacity: 0.55; transform: scale(0.96); }
    50%      { opacity: 1;    transform: scale(1.04); }
  }

  @keyframes atelierLampBulb {
    0%, 100% { opacity: 0.85; transform: scale(0.94); }
    50%      { opacity: 1;    transform: scale(1.1);  }
  }

  @keyframes atelierMoonHalo {
    0%, 100% { opacity: 0.6;  transform: scale(0.94); }
    50%      { opacity: 1;    transform: scale(1.06); }
  }

  /* Candle flame visibly flickers — scaled up so the motion reads at studio scale */
  @keyframes atelierCandleFlicker {
    0%   { transform: translate(0, 0)        scaleY(1)    scaleX(1);    opacity: 0.92; }
    20%  { transform: translate(-1.5px, 0)   scaleY(1.18) scaleX(0.88); opacity: 1;    }
    40%  { transform: translate(1.5px, 0)    scaleY(0.85) scaleX(1.18); opacity: 0.78; }
    60%  { transform: translate(-1px, -1px)  scaleY(1.22) scaleX(0.92); opacity: 1;    }
    80%  { transform: translate(0.8px, 0)    scaleY(0.92) scaleX(1.1);  opacity: 0.85; }
    100% { transform: translate(0, 0)        scaleY(1)    scaleX(1);    opacity: 0.92; }
  }

  @keyframes atelierCandleHalo {
    0%, 100% { opacity: 0.7; transform: scale(0.92); }
    33%      { opacity: 1;   transform: scale(1.08); }
    66%      { opacity: 0.6; transform: scale(0.88); }
  }

  @keyframes atelierSteamRise {
    0%   { transform: translateY(0)    translateX(0); opacity: 0.85; }
    50%  { transform: translateY(-12px) translateX(2px); opacity: 0.5;  }
    100% { transform: translateY(-26px) translateX(-1.5px); opacity: 0; }
  }

  @keyframes atelierWokFlicker {
    0%, 100% { transform: scaleY(1)    translateY(0);    opacity: 0.65; }
    50%      { transform: scaleY(1.6)  translateY(-2px); opacity: 1;    }
  }

  @keyframes atelierWokSteamRise {
    0%   { transform: translateY(0)    translateX(0); opacity: 0.8; }
    100% { transform: translateY(-22px) translateX(2px); opacity: 0.05; }
  }

  /* Tulips sway visibly — 3deg is enough to read at scale, gentle enough not to distract */
  @keyframes atelierTulipSway {
    0%, 100% { transform: rotate(-2.4deg); }
    50%      { transform: rotate(2.4deg);  }
  }

  /* Cat sleep sigh: zzz drifts up + scales (visible breathing motion) */
  @keyframes atelierCatZzz {
    0%   { transform: translateY(0)    scale(1);   opacity: 0.85; }
    50%  { transform: translateY(-6px) scale(1.1); opacity: 1;    }
    100% { transform: translateY(-14px) scale(0.9); opacity: 0;   }
  }

  /* Pendant lamp pool — gentle warm breathing (visible at scale) */
  .atelier__lamp-glow {
    transform-origin: center;
    transform-box: fill-box;
    animation: atelierLampPulse 5.2s ease-in-out infinite;
  }
  .atelier__lamp-bulb {
    transform-origin: center;
    transform-box: fill-box;
    animation: atelierLampBulb 5.2s ease-in-out infinite;
  }

  /* Moon halo over the canal — slow pulse */
  .atelier__moon-halo {
    transform-origin: center;
    transform-box: fill-box;
    animation: atelierMoonHalo 8s ease-in-out infinite;
  }

  /* Candle flame flickers, halo gently pulses */
  .atelier__candle-flame {
    transform-origin: center bottom;
    transform-box: fill-box;
    animation: atelierCandleFlicker 1.6s ease-in-out infinite;
  }
  .atelier__candle-halo {
    animation: atelierCandleHalo 3.2s ease-in-out infinite;
  }
  .atelier__candle-halo--inner {
    animation-duration: 2.4s;
    animation-delay: 0.4s;
  }

  /* Coffee steam wisps drift up and fade (alternating delays) */
  .atelier__coffee-steam {
    transform-box: fill-box;
    animation: atelierSteamRise 3.4s ease-out infinite;
  }
  .atelier__coffee-steam--b { animation-duration: 4s;   animation-delay: 0.6s; }
  .atelier__coffee-steam--c { animation-duration: 3s;   animation-delay: 1.2s; }

  /* Wok flames flicker; wok steam rises (vigorous, stir-fry energy) */
  .atelier__wok-flame {
    transform-origin: bottom;
    transform-box: fill-box;
    animation: atelierWokFlicker 0.9s ease-in-out infinite;
  }
  .atelier__wok-flame--b { animation-duration: 1.1s; animation-delay: 0.3s; }

  .atelier__wok-steam {
    transform-box: fill-box;
    animation: atelierWokSteamRise 2.8s ease-out infinite alternate;
  }
  .atelier__wok-steam--b { animation-duration: 3.4s; animation-delay: 0.5s; }
  .atelier__wok-steam--c { animation-duration: 2.4s; animation-delay: 1s;   }
  .atelier__wok-steam--d { animation-duration: 3s;   animation-delay: 1.6s; }

  /* Tulips sway as if a window is cracked open */
  .atelier__tulips {
    transform-origin: bottom center;
    transform-box: fill-box;
    animation: atelierTulipSway 5.2s ease-in-out infinite;
  }

  /* Sleeping cat: zzz drifts up + fades */
  .atelier__cat-zzz {
    transform-box: fill-box;
    animation: atelierCatZzz 3.4s ease-out infinite;
  }

  /* ============ EXTENDED IDLE MOTION (iter 10) ============
     More objects move so the room feels properly inhabited. */

  /* Stars twinkle on staggered cycles */
  @keyframes atelierStarTwinkle {
    0%, 100% { opacity: 1;   transform: scale(1);   }
    50%      { opacity: 0.25; transform: scale(0.6); }
  }
  .atelier__star {
    transform-origin: center;
