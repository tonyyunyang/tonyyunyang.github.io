    <!-- HOTSPOTS (overlay on top of SVG)
         shortLabel renders on the on-canvas tag so the initial reveal
         stays atmospheric. The full label still feeds the side panel. -->
    {
      objects.map((o) => {
        const note = "note" in o ? o.note : undefined;
        const tagLabel = "shortLabel" in o && o.shortLabel ? o.shortLabel : o.label;
        return (
          <button
            type="button"
            class="atelier__hotspot"
            data-obj-id={o.id}
            data-obj-note={note ?? ""}
            data-obj-label={o.label}
            style={`left: ${o.x}%; top: ${o.y}%;`}
            aria-label={o.label}
            disabled={!note}
          >
            <span class="atelier__hotspot-dot" aria-hidden="true" />
            <span class="atelier__hotspot-label">{tagLabel}</span>
          </button>
        );
      })
