  /* Tennis ball: subtle settle / squish (resting + breathing) */
  @keyframes atelierTennisBall {
    0%, 100% { transform: translateY(0)    scaleY(1)    scaleX(1);    }
    25%      { transform: translateY(-3px) scaleY(1.04) scaleX(0.97); }
    60%      { transform: translateY(0)    scaleY(0.95) scaleX(1.04); }
    80%      { transform: translateY(-1px) scaleY(1.02) scaleX(0.99); }
  }
  .atelier__tennis-ball {
    transform-origin: 1340px 887px;
