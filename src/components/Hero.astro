---
import siteConfig from "~/content/site.json";

const taglineLines = siteConfig.tagline;

// Render the quote as two stanzas (2 lines each)
const stanza1 = taglineLines.slice(0, 2);
const stanza2 = taglineLines.slice(2);

const card = siteConfig.businessCard;
---

<section class="hero" aria-label="Introduction">
  <!-- top corners: minimal printer's-plate header -->
  <div class="hero__corners">
    <p class="hero__corner hero__corner--left">
      <span class="hero__corner-mark" aria-hidden="true">§</span>
      No. 01 · Personal
    </p>
    <p class="hero__corner hero__corner--right">
      <span class="hero__corner-line">AMSTERDAM · 2026</span>
    </p>
  </div>

  <div class="hero__layout">
    <div class="hero__text">
      <!-- Identity card: name + role + PhD search status + specialties -->
      <div class="hero__id">
        <h1 class="hero__name">
          <span class="hero__name-en">{card.name}</span>
          <span class="hero__name-zh" aria-hidden="true">{card.nameZh}</span>
        </h1>

        <p class="hero__role">
          <span>{card.role}</span>
          <span class="hero__role-sep" aria-hidden="true">·</span>
          <span>Amsterdam</span>
        </p>

        <a class="hero__seeking" href="#contact">
          <span class="hero__seeking-mark" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 1 L9.6 6.4 L15 8 L9.6 9.6 L8 15 L6.4 9.6 L1 8 L6.4 6.4 Z" />
            </svg>
          </span>
          <span class="hero__seeking-content">
            <span class="hero__seeking-label">Open to research</span>
            <span class="hero__seeking-sep" aria-hidden="true">·</span>
            <span class="hero__seeking-when">academia or industry</span>
          </span>
          <span class="hero__seeking-arrow" aria-hidden="true">→</span>
        </a>

        <p class="hero__specialty">{card.tagline}</p>
      </div>

      <!-- Hand-drawn flourish ornament between identity and quote -->
      <svg
        class="hero__flourish"
        viewBox="0 0 280 32"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M2 16 Q40 8 84 16" stroke-width="1" />
        <circle cx="84" cy="16" r="1.4" fill="currentColor" stroke="none" />
        <path d="M92 16 Q98 6 112 6 Q126 6 132 16 Q138 26 152 26 Q166 26 172 16" stroke-width="1.4" />
        <circle cx="132" cy="16" r="2" fill="currentColor" stroke="none" />
        <path d="M180 16 Q200 24 220 18 Q240 12 264 16" stroke-width="1" />
        <path d="M264 16 L278 16" stroke-width="1" />
        <circle cx="180" cy="16" r="1.4" fill="currentColor" stroke="none" />
      </svg>

      <!-- Quote: the only fancy italic display, smaller than before -->
      <blockquote class="hero__quote">
        <span class="hero__stanza">
          {stanza1.map((line) => <span class="hero__line">{line}</span>)}
        </span>
        <span class="hero__stanza">
          {stanza2.map((line) => <span class="hero__line">{line}</span>)}
        </span>
      </blockquote>
    </div>

    <!-- Hand-drawn vignette: window onto an Amsterdam canal at twilight,
         with a writing tableau on the sill below.
         Wrapped in an <a> so it doubles as a portal into the Studio. -->
    <a class="hero__sketch-link" href="/world/" aria-label="Step inside the studio">
    <!-- Persistent rest-state cue: tiny emerald tag signals the sketch is interactive -->
    <span class="hero__sketch-tag" aria-hidden="true">
      <span class="hero__sketch-tag-text">studio</span>
      <span class="hero__sketch-tag-arrow">↗</span>
    </span>
    <svg
      class="hero__sketch"
      viewBox="0 0 360 540"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <defs>
        <pattern id="heroHatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(35)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="0.4" opacity="0.42" />
        </pattern>
        <pattern id="heroHatchFine" patternUnits="userSpaceOnUse" width="4" height="4" patternTransform="rotate(-30)">
          <line x1="0" y1="0" x2="0" y2="4" stroke="currentColor" stroke-width="0.3" opacity="0.32" />
        </pattern>
        <radialGradient id="heroMoonHalo" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FAF1D8" stop-opacity="0.85" />
          <stop offset="0.55" stop-color="#FAF1D8" stop-opacity="0.35" />
          <stop offset="1" stop-color="#FAF1D8" stop-opacity="0" />
        </radialGradient>
      </defs>

      <!-- top margin annotation -->
      <circle cx="40" cy="22" r="1.4" fill="currentColor" stroke="none" />
      <circle cx="48" cy="22" r="1.4" fill="currentColor" stroke="none" />
      <text x="60" y="27" font-family="EB Garamond, serif" font-style="italic" font-size="18" fill="currentColor" stroke="none" opacity="0.7">a window onto more</text>

      <!-- arched window frame, hatched corners, keystone -->
      <path d="M48 70 Q48 44 88 44 H272 Q312 44 312 70 V296 H48 Z" stroke-width="2" fill="#FAF1D8" />
      <path d="M56 78 Q56 52 90 52 H270 Q304 52 304 78 V288 H56 Z" stroke-width="0.6" opacity="0.55" fill="none" />
      <path d="M174 44 L174 60 L186 60 L186 44 Z" stroke-width="0.9" fill="#EDE6D5" />
      <path d="M178 48 L178 56 M182 48 L182 56" stroke-width="0.4" opacity="0.55" />
      <rect x="48" y="70" width="24" height="6" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="48" y="70" width="6" height="24" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="288" y="70" width="24" height="6" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="306" y="70" width="6" height="24" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="48" y="290" width="24" height="6" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="48" y="272" width="6" height="24" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="288" y="290" width="24" height="6" fill="url(#heroHatch)" opacity="0.7" />
      <rect x="306" y="272" width="6" height="24" fill="url(#heroHatch)" opacity="0.7" />

      <!-- sky pane + warm hatch -->
      <rect x="56" y="78" width="248" height="100" fill="#FAF1D8" />
      <rect x="56" y="78" width="248" height="60" fill="url(#heroHatchFine)" opacity="0.6" />

      <!-- moon halo + crescent -->
      <circle class="hero__sketch-moon-halo" cx="252" cy="106" r="42" fill="url(#heroMoonHalo)" stroke="none" opacity="0.9" />
      <circle cx="252" cy="106" r="16" fill="#FAF1D8" stroke-width="1.4" />
      <circle cx="246" cy="102" r="13" fill="#FAF1D8" stroke="none" />
      <path d="M252 90 A 16 16 0 0 1 268 106 A 16 16 0 0 1 252 122 A 14 14 0 0 0 252 90 Z" fill="currentColor" opacity="0.18" stroke="none" />
      <circle cx="259" cy="100" r="1.4" fill="currentColor" opacity="0.35" stroke="none" />
      <circle cx="262" cy="111" r="0.9" fill="currentColor" opacity="0.3" stroke="none" />

      <!-- stars (twinkle on staggered cycles) -->
      <circle class="hero__sketch-star hero__sketch-star--a" cx="78" cy="92" r="1.1" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--b" cx="86" cy="100" r="0.7" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--c" cx="106" cy="86" r="0.9" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--d" cx="124" cy="116" r="1.2" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--e" cx="138" cy="98" r="0.6" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--f" cx="152" cy="124" r="0.9" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--a" cx="170" cy="92" r="0.7" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--c" cx="188" cy="118" r="0.6" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--e" cx="206" cy="98" r="0.9" fill="currentColor" stroke="none" />
      <circle class="hero__sketch-star hero__sketch-star--b" cx="222" cy="138" r="0.6" fill="currentColor" stroke="none" />
      <!-- small radiated stars -->
      <path d="M118 84 L118 80 M118 84 L118 88 M118 84 L114 84 M118 84 L122 84" stroke-width="0.6" opacity="0.7" />
      <path d="M196 134 L196 131 M196 134 L196 137 M196 134 L193 134 M196 134 L199 134" stroke-width="0.5" opacity="0.6" />

      <!-- bird in flight, gentle V -->
      <path d="M158 80 Q162 76 166 80 Q170 76 174 80" stroke-width="0.8" opacity="0.7" />
      <path d="M178 88 Q182 85 186 88" stroke-width="0.6" opacity="0.55" />

      <!-- gabled silhouette + church spire -->
      <path
        d="M56 178 L70 178 L70 162 L80 162 L80 152 L92 152 L92 162 L106 162 L106 178 L120 178 L120 156 L130 150 L140 142 L150 150 L160 156 L160 178 L172 178 L172 158 L184 158 L184 168 L196 168 L196 158 L208 158 L208 178 L222 178 L218 168 L226 158 L228 154 L228 130 L226 124 L232 124 L232 102 L236 100 L240 102 L240 124 L246 124 L244 130 L244 154 L246 158 L254 168 L250 178 L268 178 L268 152 L280 152 L280 144 L294 144 L294 156 L304 156 L304 178"
        stroke-width="1.4"
        fill="#EDE6D5"
      />
      <path d="M236 96 L236 100 M234 98 L238 98" stroke-width="0.8" />
      <circle cx="236" cy="124" r="1.4" fill="currentColor" opacity="0.7" stroke="none" />

      <!-- chimneys with smoke -->
      <rect x="86" y="146" width="3" height="6" fill="currentColor" opacity="0.85" stroke="none" />
      <rect x="142" y="138" width="3" height="6" fill="currentColor" opacity="0.85" stroke="none" />
      <rect x="278" y="138" width="3" height="6" fill="currentColor" opacity="0.85" stroke="none" />
      <path class="hero__sketch-smoke hero__sketch-smoke--a" d="M88 146 Q86 138 90 132 Q94 126 90 120" stroke-width="0.5" opacity="0.5" />
      <path class="hero__sketch-smoke hero__sketch-smoke--b" d="M144 138 Q142 130 146 124 Q150 118 146 112" stroke-width="0.5" opacity="0.5" />
      <path class="hero__sketch-smoke hero__sketch-smoke--c" d="M280 138 Q278 130 282 124" stroke-width="0.5" opacity="0.5" />

      <!-- lit windows in distant houses -->
      <rect x="76" y="168" width="3" height="5" fill="#0E5347" opacity="0.9" stroke="none" />
      <rect x="86" y="170" width="3" height="4" fill="currentColor" opacity="0.65" stroke="none" />
      <rect x="98" y="168" width="3" height="5" fill="#0E5347" opacity="0.9" stroke="none" />
      <rect x="128" y="160" width="3" height="5" fill="#0E5347" opacity="0.9" stroke="none" />
      <rect x="142" y="158" width="3" height="5" fill="currentColor" opacity="0.6" stroke="none" />
      <rect x="176" y="166" width="3" height="5" fill="currentColor" opacity="0.65" stroke="none" />
      <rect x="200" y="166" width="3" height="5" fill="#0E5347" opacity="0.9" stroke="none" />
      <rect x="232" y="138" width="2" height="3" fill="#FAF1D8" opacity="0.95" stroke="none" />
      <rect x="232" y="146" width="2" height="3" fill="#FAF1D8" opacity="0.85" stroke="none" />
      <rect x="270" y="160" width="3" height="5" fill="currentColor" opacity="0.65" stroke="none" />
      <rect x="284" y="156" width="3" height="5" fill="#0E5347" opacity="0.9" stroke="none" />

      <!-- canal water -->
      <rect x="56" y="180" width="248" height="62" fill="#EDE6D5" />
      <path d="M56 180 H304" stroke-width="0.7" />
      <!-- moon reflection broken into ripple bits -->
      <path d="M244 192 H262 M242 200 H264 M246 208 H260" stroke-width="1" opacity="0.55" stroke="#FAF1D8" />
      <!-- ripples -->
      <path d="M62 198 Q78 195 94 198 Q110 201 126 198 Q142 195 158 198 Q174 201 190 198 Q206 195 222 198 Q238 201 254 198 Q270 195 286 198 Q298 200 302 198" stroke-width="0.5" opacity="0.65" />
      <path d="M62 210 Q78 207 94 210 Q110 213 126 210 Q142 207 158 210 Q174 213 190 210 Q206 207 222 210" stroke-width="0.5" opacity="0.5" />
      <path d="M62 222 Q78 219 94 222 Q110 225 126 222 Q142 219 158 222 Q174 225 190 222 Q206 219 222 222 Q238 225 254 222 Q270 219 286 222 Q298 224 302 222" stroke-width="0.5" opacity="0.4" />
      <path d="M62 234 Q78 231 94 234 Q110 237 126 234 Q142 231 158 234 Q174 237 190 234" stroke-width="0.4" opacity="0.3" />

      <!-- canal boat: simple flat-bottomed punt with two oars (no mast) -->
      <g class="hero__sketch-boat">
        <!-- hull -->
        <path d="M86 222 Q88 218 100 218 L142 218 Q154 218 156 222 L150 232 L92 232 Z" stroke-width="0.9" fill="currentColor" opacity="0.85" />
        <!-- water line under hull -->
        <path d="M86 232 H156" stroke-width="0.5" opacity="0.6" />
        <!-- two oars sticking out at angles -->
        <path d="M104 218 L92 208" stroke-width="0.7" opacity="0.85" />
        <path d="M138 218 L150 208" stroke-width="0.7" opacity="0.85" />
        <!-- tiny figure rowing (silhouette) -->
        <path d="M118 218 L118 212 Q118 209 121 209 Q124 209 124 212 L124 218 Z" stroke-width="0.6" fill="#FAF1D8" />
        <circle cx="121" cy="206" r="2" fill="currentColor" opacity="0.85" stroke="none" />
      </g>

      <!-- mullion + transom -->
      <path d="M180 78 V242" stroke-width="1.4" />
      <path d="M56 178 H304" stroke-width="1" opacity="0.85" />

      <!-- sill -->
      <path d="M40 242 H320 V258 H40 Z" fill="#EDE6D5" stroke-width="1.4" />
      <path d="M40 258 H320" stroke-width="0.5" opacity="0.55" />
      <path d="M44 262 H316" stroke-width="0.4" opacity="0.4" stroke-dasharray="1 3" />

      <!-- letters tied with ribbon (right) -->
      <g>
        <rect x="244" y="368" width="64" height="9" fill="#FAF1D8" stroke-width="0.9" transform="rotate(-3 276 372)" />
        <rect x="244" y="376" width="64" height="9" fill="#EDE6D5" stroke-width="0.9" transform="rotate(-3 276 380)" />
        <rect x="244" y="384" width="64" height="9" fill="#FAF1D8" stroke-width="0.9" transform="rotate(-3 276 388)" />
        <circle cx="288" cy="370" r="2.6" fill="#0E5347" stroke="none" />
        <path d="M270 366 L270 396" stroke-width="2.2" stroke="#0E5347" />
        <path d="M266 396 L264 404 L272 400 L270 408" stroke-width="1" stroke="#0E5347" />
      </g>

      <!-- open book -->
      <g>
        <path d="M120 412 L240 412 L246 426 L114 426 Z" stroke-width="1.3" fill="#0F1417" opacity="0.3" />
        <path d="M118 360 L180 358 L180 412 L120 412 Z" stroke-width="1.3" fill="#FAF1D8" />
        <path d="M180 358 L242 360 L240 412 L180 412 Z" stroke-width="1.3" fill="#FAF1D8" />
        <path d="M180 358 L180 412" stroke-width="1.1" opacity="0.85" />
        <path d="M178 359 L178 410 M182 359 L182 410" stroke-width="0.4" opacity="0.5" />
        <path d="M126 372 H172 M126 378 H170 M126 384 H172 M126 390 H164 M126 396 H170" stroke-width="0.4" opacity="0.55" />
        <path d="M188 372 H234 M188 378 H232 M188 384 H236 M188 390 H230 M188 396 H232" stroke-width="0.4" opacity="0.55" />
        <path d="M180 358 L184 432 L186 422 L188 432 L188 358" stroke-width="0.7" fill="#0E5347" opacity="0.9" />
      </g>

      <!-- spectacles atop book -->
      <g>
        <circle cx="148" cy="356" r="9" stroke-width="1.2" fill="#FAF1D8" />
        <circle cx="170" cy="356" r="9" stroke-width="1.2" fill="#FAF1D8" />
        <path d="M157 356 L161 356" stroke-width="1.1" />
        <path d="M139 356 L130 350 L126 354" stroke-width="0.9" />
        <path d="M179 356 L188 350 L192 354" stroke-width="0.9" />
        <path d="M144 352 Q146 350 150 350" stroke-width="0.4" opacity="0.6" />
        <path d="M166 352 Q168 350 172 350" stroke-width="0.4" opacity="0.6" />
      </g>

      <!-- inkwell + quill (left) -->
      <g>
        <ellipse cx="80" cy="380" rx="20" ry="5" fill="#0F1417" stroke-width="1" />
        <path d="M60 380 Q60 412 80 412 Q100 412 100 380 Z" stroke-width="1.4" fill="#0F1417" />
        <ellipse cx="80" cy="378" rx="16" ry="3" fill="none" stroke-width="0.5" stroke="#FAF1D8" opacity="0.5" />
      </g>
      <g>
        <path d="M86 380 L46 296 L52 292 L92 376 Z" stroke-width="1.1" fill="#FAF1D8" />
        <path d="M52 312 L60 308 M56 322 L66 318 M60 332 L70 328 M64 342 L74 338 M68 352 L78 348 M72 362 L82 358" stroke-width="0.5" opacity="0.7" />
        <path d="M62 308 L48 304 M66 318 L52 314 M70 328 L56 324 M74 338 L60 334 M78 348 L64 344 M82 358 L68 354" stroke-width="0.4" opacity="0.6" />
        <path d="M82 376 L92 380 L88 384 Z" fill="currentColor" />
        <circle cx="92" cy="392" r="1.2" fill="#0E5347" stroke="none" />
      </g>

      <!-- teacup at far right -->
      <g opacity="0.9">
        <path d="M298 412 Q298 422 308 422 L314 422 Q324 422 324 412 V404 H298 Z" stroke-width="0.7" fill="#FAF1D8" />
        <ellipse cx="311" cy="404" rx="13" ry="2" stroke-width="0.6" fill="#0E5347" opacity="0.5" />
        <path d="M324 408 Q330 408 330 414 Q330 418 324 418" stroke-width="0.7" fill="none" />
        <path class="hero__sketch-steam hero__sketch-steam--a" d="M304 400 Q302 394 306 388" stroke-width="0.5" opacity="0.65" fill="none" />
        <path class="hero__sketch-steam hero__sketch-steam--b" d="M314 400 Q312 394 316 388" stroke-width="0.5" opacity="0.55" fill="none" />
      </g>

      <!-- bottom margin annotation -->
      <text x="40" y="464" font-family="EB Garamond, serif" font-style="italic" font-size="18" fill="currentColor" stroke="none" opacity="0.7">and we dwell here.</text>
      <path d="M44 474 L300 474" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.55" />
      <circle cx="304" cy="474" r="1.4" fill="currentColor" stroke="none" opacity="0.6" />

      <!-- plate label -->
      <path d="M40 502 H320" stroke-width="0.4" opacity="0.4" />
      <text x="40" y="518" font-family="JetBrains Mono, monospace" font-size="11" fill="currentColor" stroke="none" letter-spacing="0.18em" opacity="0.75">PLATE I · TWILIGHT</text>
      <text x="320" y="518" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="11" fill="currentColor" stroke="none" letter-spacing="0.18em" opacity="0.75">2026</text>
    </svg>
    </a>
  </div>

  <!-- Scroll cue: friendly invitation, animated chevron -->
  <a class="hero__cue" href="#currently" aria-label="Scroll to introduction">
    <span class="hero__cue-text">scroll for the work</span>
    <span class="hero__cue-chevron" aria-hidden="true">
      <svg viewBox="0 0 16 22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 1 V19" />
        <path d="M2 13 L8 19 L14 13" />
      </svg>
    </span>
  </a>

  <p class="hero__hint" aria-hidden="true">
    or <kbd>⌘K</kbd>
  </p>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 32px 32px 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: var(--content-with-rail);
    margin-inline: auto;
  }

  .hero__corners {
    position: absolute;
    top: 32px;
    left: 32px;
    right: 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  .hero__corner {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    line-height: 1.7;
  }

  .hero__corner-mark {
    display: inline-block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-accent);
    margin-right: 6px;
    vertical-align: -1px;
  }

  .hero__corner-line {
    display: block;
  }

  .hero__corner--right {
    text-align: right;
  }

  .hero__layout {
    display: block;
    position: relative;
    z-index: 1;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    max-width: 100%;
  }

  /* ============ IDENTITY CARD ============ */

  .hero__id {
    display: flex;
    flex-direction: column;
    gap: 22px;
    margin-bottom: 8px;
  }

  .hero__name {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-style: normal; /* upright EB Garamond — elegant + readable, not "fancy" */
    font-weight: 400;
    font-size: clamp(48px, 6.4vw, 84px);
    line-height: 1.05;
    letter-spacing: -0.012em;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 22px;
    flex-wrap: wrap;
  }

  .hero__name-en {
    /* upright */
  }

  .hero__name-zh {
    font-family: var(--font-display-zh);
    /* LXGW WenKai is a humanist, calligraphic Chinese face that pairs warmly
       with EB Garamond. Size eased down so the Chinese reads as a companion
       to the Latin name rather than competing with it. */
    font-weight: 500;
    font-size: 0.44em;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
    /* Visually align Chinese caps to Latin caps */
    transform: translateY(-0.04em);
  }

  .hero__role {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink);
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero__role-sep {
    color: var(--color-ink-soft);
    opacity: 0.7;
  }

  /* The "open to research" callout: prominent, emerald, the active status pill
     that anchors to #contact. Frames Tony as open to research in academia or
     industry — not pinned to a PhD job-search frame. */
  .hero__seeking {
    margin: 6px 0 0;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    align-self: flex-start;
    font-family: var(--font-mono);
